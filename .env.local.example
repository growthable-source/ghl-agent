OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
APP_URL=https://your-app.vercel.app
INSTALL_URL_STANDARD=
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://...?sslmode=require
DIRECT_URL=postgresql://...?sslmode=require

# Customer-portal auth. Falls back to NEXTAUTH_SECRET if unset, but a
# dedicated value keeps portal sessions independent of NextAuth rotations.
PORTAL_SESSION_SECRET=
# Optional override for the From address on portal invite emails.
# Falls back to NOTIFICATION_FROM_EMAIL.
PORTAL_FROM_EMAIL=
