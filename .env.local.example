OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
APP_URL=https://your-app.vercel.app
INSTALL_URL_STANDARD=

# Shared Secret(s) from the marketplace app settings — used to decrypt the
# SSO identity blob inside CRM iframes. _2 is for a second marketplace app
# (e.g. the agency portal-wrapper app) pointing at the same deployment.
LEADCONNECTOR_SSO_KEY=
LEADCONNECTOR_SSO_KEY_2=
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://...?sslmode=require
DIRECT_URL=postgresql://...?sslmode=require

# Customer-portal auth. Falls back to NEXTAUTH_SECRET if unset, but a
# dedicated value keeps portal sessions independent of NextAuth rotations.
PORTAL_SESSION_SECRET=
# Optional override for the From address on portal invite emails.
# Falls back to NOTIFICATION_FROM_EMAIL.
PORTAL_FROM_EMAIL=

# ── Real-time Co-Pilot (screen-share + voice) ──────────────────────
# Server-side only — the browser receives short-lived ephemeral
# tokens, never this key. Create at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Comma-separated workspace ids force-enabled pre-GA regardless of
# plan tier (dogfood allowlist). At GA the Scale plan flag gates it.
COPILOT_WORKSPACE_ALLOWLIST=
# Optional overrides (defaults shown)
# COPILOT_MODEL_PRIMARY=gemini-3.1-flash-live-preview
# COPILOT_MAX_SESSION_SECS=1800
# COPILOT_FRAME_FPS_CAP=1
# Optional prebuilt voice override (e.g. Puck, Kore). Accent otherwise
# follows the session locale, which follows the user's browser.
# COPILOT_VOICE=

# ── Voice agents (Vapi) ────────────────────────────────────────────────
# Server API key from dashboard.vapi.ai → Vapi API Keys. Gates all
# assistant registration, phone-number purchase, and outbound dialing.
VAPI_API_KEY=
# PUBLIC key (a separate value on the same Vapi dashboard page). The
# browser's @vapi-ai/web SDK needs it for test calls + widget voice.
# Without it the dashboard test-call preflight fails its first check.
VAPI_PUBLIC_KEY=
# Shared secret echoed back by Vapi as the x-vapi-secret header. When
# set, /api/vapi/webhook rejects requests without it — REQUIRED for a
# production deploy (the webhook executes booking/SMS/tagging tools).
# After setting or rotating it, re-save each voice agent so its
# registered assistant picks up the new secret.
VAPI_WEBHOOK_SECRET=
# Optional: ElevenLabs key for the extended voice catalogue.
ELEVENLABS_API_KEY=
# Optional model/transcriber overrides (defaults: openai/gpt-4.1 +
# deepgram/nova-3 — the stack verified end-to-end on Vapi).
# VAPI_DEFAULT_MODEL_PROVIDER=openai
# VAPI_DEFAULT_MODEL=gpt-4.1
# VAPI_DEFAULT_TRANSCRIBER_PROVIDER=deepgram
# VAPI_DEFAULT_TRANSCRIBER_MODEL=nova-3
