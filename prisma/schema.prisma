generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ──────────────────────────────────────────────────────

model User {
  id                        String               @id @default(cuid())
  name                      String?
  email                     String?              @unique
  emailVerified             DateTime?
  image                     String?
  theme                     String               @default("soft-light")
  companyName               String?
  companySize               String?
  role                      String?
  onboardingCompletedAt     DateTime?
  accounts                  Account[]
  sessions                  Session[]
  locations                 UserLocation[]
  workspaces                WorkspaceMember[]
  assignedConversations     WidgetConversation[] @relation("ConversationAssignee")
  assignedMetaConversations MetaConversation[]   @relation("MetaConversationAssignee")
  assignedTickets           Ticket[]             @relation("TicketAssignee")
  createdTickets            Ticket[]             @relation("TicketCreator")
  conversationNotes         ConversationNote[]   @relation("ConversationNoteAuthor")
  authoredTicketMessages    TicketMessage[]      @relation("TicketMessageAuthor")
  submittedTicketDrafts     TicketReplyDraft[]   @relation("TicketDraftSubmitter")
  sentMetaMessages          MetaMessage[]        @relation("MetaMessageAuthor")
  kioskOperator             KioskOperator?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserLocation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  role       String   @default("owner")
  createdAt  DateTime @default(now())

  @@unique([userId, locationId])
}

// ─── Workspace Architecture ──────────────────────────────────────────────────

model Workspace {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  icon    String  @default("🚀") // emoji avatar — fallback when logoUrl is unset
  // Optional hosted logo image. When set, the UI renders this instead of
  // the emoji everywhere the workspace avatar appears (sidebar, switcher,
  // workspace list). Either a Vercel Blob URL (from our upload endpoint)
  // or any arbitrary https URL the user pasted — we don't proxy or copy,
  // so broken external URLs just render as a broken image.
  logoUrl String?
  domain  String? // e.g. "acmecorp.com" — for same-domain invite gating

  // ─── Plan & Limits ───
  plan                    String    @default("trial") // "trial" | "starter" | "growth" | "scale"
  planSelectedDuringTrial String? // "starter" | "growth" | "scale"
  billingPeriod           String    @default("monthly") // "monthly" | "annual"
  agentLimit              Int       @default(3)
  messageLimit            Int       @default(1500) // AI messages per billing period
  messageUsage            Int       @default(0) // current period usage
  voiceMinuteLimit        Int       @default(0) // voice minutes per billing period (seconds stored)
  voiceMinuteUsage        Int       @default(0) // current period voice usage in seconds
  extraAgentCount         Int       @default(0) // agents beyond plan inclusion
  trialEndsAt             DateTime? // set to now+7d on signup

  // ─── Stripe Billing ───
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // ─── Install provenance + primary CRM ───
  // installSource records where this workspace was created from — set
  // once at signup, never rewritten. Drives onboarding copy, marketplace
  // attribution, and the integrations page's "Recommended for your setup"
  // subtitle. Values: 'direct' | 'ghl_marketplace' | 'shopify_app' |
  // 'hubspot_marketplace'. NULL on legacy workspaces created before this
  // column existed — the UI treats NULL the same as 'direct'.
  installSource      String?
  // primaryCrmProvider drives sort order on the integrations page and the
  // default for new agents. Mutable: when a workspace on 'native' connects
  // its first paid CRM, this flips automatically; further CRMs require an
  // explicit "Use as primary" click (matches the existing HubSpot button).
  primaryCrmProvider String  @default("native")

  /// 'tool_disable' (default) — drop the affected tools and keep the rest running.
  /// 'agent_pause' — skip the agent entirely when any reference is broken.
  /// 'warn_only' — runtime ignores broken state; rely on the runtime fallback.
  brokenReferenceMode String @default("tool_disable")

  // ─── Emergency Pause ───
  isPaused Boolean   @default(false)
  pausedAt DateTime?
  pausedBy String? // userId who paused the workspace

  // ─── Platform Learnings opt-out ───
  // When true, this workspace's agents do NOT receive the shared
  // "## Platform Guidelines" block injected by approved global learnings.
  // Escape hatch for customers with very specific tone requirements
  // that conflict with platform-wide guidance. Workspace-scoped learnings
  // (scope=workspace) are unaffected — those are still the operator's
  // own opt-in choices.
  disableGlobalLearnings Boolean @default(false)

  members              WorkspaceMember[]
  invites              WorkspaceInvite[]
  locations            Location[]            @relation("WorkspaceLocations")
  agents               Agent[]               @relation("WorkspaceAgents")
  agentFolders         AgentFolder[]
  usageRecords         UsageRecord[]
  templates            AgentTemplate[]       @relation("WorkspaceTemplates")
  knowledgeEntries     KnowledgeEntry[]      @relation("WorkspaceKnowledge")
  knowledgeCollections KnowledgeCollection[] @relation("WorkspaceKnowledgeCollections")
  brands               Brand[]               @relation("WorkspaceBrands")
  brandGroups          BrandGroup[]          @relation("WorkspaceBrandGroups")
  knowledgeDomains     KnowledgeDomain[]     @relation("WorkspaceKnowledgeDomains")
  tickets              Ticket[]              @relation("WorkspaceTickets")
  ticketingSettings    TicketingSettings?
  liveChatSettings     LiveChatSettings?
  kioskCredential      KioskCredential?
  kioskOperators       KioskOperator[]
  copilotSessions      CopilotSession[]      @relation("WorkspaceCopilotSessions")
  copilotSops          CopilotSop[]          @relation("WorkspaceCopilotSops")
  copilotAgents        CopilotAgent[]        @relation("WorkspaceCopilotAgents")
  agencyConnections    AgencyConnection[]

  // ─── Native (built-in) CRM ───
  // Populated only for workspaces using crmProvider='native' on their
  // Location. Workspaces still on GHL/HubSpot leave these collections empty.
  nativeContacts       NativeContact[]
  nativeContactLists   NativeContactList[]
  nativeContactImports NativeContactImport[]
  nativeSuppressions   NativeSuppression[]
  nativeConversations  NativeConversation[]
  nativeMessages       NativeMessage[]
  nativeCustomFields   NativeCustomField[]

  // ─── Marketplace install registry ───
  // One MarketplaceInstall row per (workspace, install event). For
  // marketplace OAuth callbacks we snapshot the installing user +
  // location + company at install time so the admin backend has
  // a permanent lead record even if the user disconnects later.
  marketplaceInstalls MarketplaceInstall[]

  // ─── Xovera commerce layer ───
  // One Shopify store per workspace (MVP — drop @unique on
  // ShopifyShop.workspaceId to support multi-store later).
  shopifyShop ShopifyShop? @relation("WorkspaceShopify")

  // ─── Workspace-defined agent presets ───
  // User-saved "Save as preset" templates from the agent tool rules
  // editor. Coexists with the hardcoded registry at lib/agent/presets.ts.
  presets WorkspacePreset[]

  // ─── External API access ───
  ApiKeys     ApiKey[]
  SlaPolicies SlaPolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UsageRecord {
  id                  String    @id @default(cuid())
  workspaceId         String
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type                String // "message" | "voice_minute"
  quantity            Int // 1 for messages, seconds for voice
  agentId             String? // which agent generated the usage
  billingPeriod       String // e.g. "2026-04"
  stripeUsageRecordId String? // after reporting to Stripe
  createdAt           DateTime  @default(now())

  @@index([workspaceId, billingPeriod])
  @@index([workspaceId, type, createdAt])
}

// ─── LLM cost telemetry ────────────────────────────────────────────────────
// Daily rollup of model calls so realized inference cost (and DeepSeek
// savings vs Claude) is provable per workspace/surface/model. Written
// best-effort, fire-and-forget, by lib/llm/createMessage — never blocks a
// reply. workspaceId '' = unattributed. modelKey = the model actually USED
// (after capability/reliability escalation); fellBackCalls counts how often
// a cheaper model escalated to Claude.
model LlmUsageDaily {
  id                       String   @id @default(cuid())
  day                      String // 'YYYY-MM-DD' UTC
  workspaceId              String   @default("")
  surface                  String // 'agent' | 'summary' | 'ad-generator' | …
  modelKey                 String // model actually used, e.g. 'deepseek-flash'
  provider                 String // 'anthropic' | 'openai-compat'
  calls                    Int      @default(0)
  fellBackCalls            Int      @default(0)
  inputTokens              BigInt   @default(0)
  outputTokens             BigInt   @default(0)
  // Anthropic prompt-cache accounting. cacheRead bills at ~10% of base
  // input; cacheCreation at ~125%. Lets us prove caching engaged and
  // quantify the saving per workspace/surface. Always 0 on openai-compat.
  cacheReadInputTokens     BigInt   @default(0)
  cacheCreationInputTokens BigInt   @default(0)
  updatedAt                DateTime @updatedAt

  @@unique([day, workspaceId, surface, modelKey])
  @@index([day])
  @@index([workspaceId, day])
}

/// Snapshot of a marketplace install at the moment it happened.
/// Powers the admin backend's lead-tracking view: "who installed this
/// week, what agency are they part of, what's their email." Separate
/// from operational state (Workspace/Location) so the lead record
/// persists even if the customer later disconnects or the underlying
/// Location row gets cleaned up.
///
/// One row per install event — a reinstall from the same user creates
/// a new row, so we keep a history. Query by installedAt for "new this
/// week" reports; query by source for "Shopify vs HighLevel mix".
model MarketplaceInstall {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Source of the install. Mirrors Workspace.installSource but stored
  // here too so a `SELECT * FROM MarketplaceInstall` is self-contained.
  source      String // 'ghl_marketplace' | 'shopify_app' | 'hubspot_marketplace'
  installedAt DateTime @default(now())

  // Foreign identifiers from the marketplace side. Keeping them as
  // strings (not FKs) because the Location row gets cleaned up on
  // disconnect — the snapshot should survive that.
  externalLocationId String?
  externalCompanyId  String?
  externalUserId     String?

  // ─── Location snapshot ─── (GET /locations/{id})
  locationName     String?
  locationEmail    String?
  locationPhone    String?
  locationWebsite  String?
  locationAddress  String?
  locationCity     String?
  locationState    String?
  locationCountry  String?
  locationTimezone String?

  // ─── Company snapshot ─── (GET /companies/{id} — may 403 if our
  // OAuth grant doesn't include companies.readonly; saved fields stay
  // NULL in that case)
  companyName    String?
  companyEmail   String?
  companyPhone   String?
  companyWebsite String?

  // ─── Installing user snapshot ─── (GET /users/{id})
  userName  String?
  userEmail String?
  userPhone String?
  userRole  String? // 'admin' | 'user' from GHL

  // ─── Admin pipeline ───
  // contactedAt:  the date our team first reached out (set from the
  //               admin UI when an SDR works the lead).
  // syncedToGhlAt: timestamp of the most recent successful push to
  //               our own GHL CRM (the "Sync to my GHL CRM" button).
  // notes:        free-text admin notes — kept here rather than on a
  //               separate audit table because there's only one row
  //               per install and we don't need versioning.
  contactedAt   DateTime?
  syncedToGhlAt DateTime?
  notes         String?

  // Raw response bodies, kept for forensic + future-proofing. If GHL
  // adds a field we want to surface, we can backfill from rawPayload
  // without re-calling the API on every old install.
  rawPayload Json?

  @@index([workspaceId])
  @@index([installedAt])
  @@index([source, installedAt])
}

model WorkspaceMember {
  id                    String                @id @default(cuid())
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId           String
  workspace             Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role                  String                @default("owner") // "owner" | "admin" | "member"
  // Weekly digest delivery — per-user opt-in. Cron checks this before
  // dispatching; the digest page exposes a toggle.
  digestOptIn           Boolean               @default(true)
  lastDigestSentAt      DateTime?
  // Inbox availability. Routing engine only assigns chats to members
  // marked available; "away" members stay in the workspace but are
  // skipped by round-robin / first-available picks. Toggled from the
  // inbox header.
  isAvailable           Boolean               @default(true)
  availabilityChangedAt DateTime?
  // What caused the CURRENT isAvailable value. 'self' = the member
  // toggled the inbox pill; 'system' = auto-away flipped them (and a
  // fresh heartbeat may flip them back); 'kiosk' = kiosk admin action.
  // Auto-return ONLY overrides 'system' — a deliberate human/admin
  // choice is never undone by a mouse wiggle.
  presenceSource        String                @default("self")
  // Last time the dashboard heartbeat (or a reply) saw this member
  // actually doing something. Null = never seen by the heartbeat —
  // the auto-away cron skips those members entirely, so the feature
  // self-bootstraps per member with no mass flip on rollout.
  lastActivityAt        DateTime?
  createdAt             DateTime              @default(now())
  presenceEvents        MemberPresenceEvent[]

  @@unique([userId, workspaceId])
  @@index([workspaceId, isAvailable])
  @@index([isAvailable, lastActivityAt])
}

// Audit trail of when a member toggled their availability. Powers the
// "agent activity" view so an owner can see when each operator was
// online vs away over the last few days, which makes coverage planning
// and post-incident review easy.
model MemberPresenceEvent {
  id          String          @id @default(cuid())
  memberId    String
  member      WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  workspaceId String
  // 'available' | 'away' — present-tense state the member transitioned
  // INTO. Read as a strict alternation: every consecutive pair forms
  // an active-from / away-from interval.
  state       String
  // What flipped it. 'self' = the member toggled in the inbox header.
  // 'system' = future hooks (auto-away after N min idle, signed-out,
  // login from new tab). Left open so we can extend without migrating.
  source      String          @default("self")
  createdAt   DateTime        @default(now())

  @@index([memberId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        String    @default("member") // "owner" | "admin" | "member" | "viewer"
  invitedBy   String // userId of inviter
  // Single-use opaque token the invitee follows to accept. Generated
  // server-side on create + resend so a leaked invite from an old
  // expiry can't be reused once we re-issue.
  token       String    @unique @default(cuid())
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, email])
  @@index([email])
  @@index([token])
}

enum ConversationState {
  ACTIVE
  PAUSED
  COMPLETED
}

enum StopConditionType {
  APPOINTMENT_BOOKED
  KEYWORD
  MESSAGE_COUNT
  OPPORTUNITY_STAGE
  // Matches hostile / angry / threatening language in inbound messages.
  // Uses a built-in regex plus any extra keywords the operator adds via
  // `value`. When tripped, pauses the agent and (via the action columns
  // on StopCondition) tags needs-attention / enrols workflows.
  SENTIMENT
}

enum FollowUpStatus {
  SCHEDULED
  SENT
  CANCELLED
  FAILED
}

enum ResponseLength {
  BRIEF
  MODERATE
  DETAILED
}

enum FormalityLevel {
  CASUAL
  NEUTRAL
  FORMAL
}

// Shopify store connection — workspace-scoped (one store per workspace
// for MVP; drop the @unique on workspaceId to allow multi-store).
//
// `id` is the canonical *.myshopify.com domain (e.g.
// "xovera-dev.myshopify.com"), which is what Shopify uses everywhere —
// admin API host, webhook payload `X-Shopify-Shop-Domain` header, and
// the OAuth `shop` query param. Storing it as the PK lets webhook
// handlers (which only know the shop domain, not workspaceId) look up
// the row in one hop.
//
// No refresh token: Shopify offline access tokens don't expire. App
// uninstall revokes the token server-side; we mark `uninstalledAt`
// from the `app/uninstalled` webhook so reads can short-circuit.
model ShopifyShop {
  id            String    @id
  workspaceId   String    @unique
  workspace     Workspace @relation("WorkspaceShopify", fields: [workspaceId], references: [id], onDelete: Cascade)
  accessToken   String
  // Refresh token + expiresAt are populated only for the new expiring
  // offline token model (Shopify rolled out 2026; older non-expiring
  // tokens are now rejected with HTTP 403). Nullable for backward
  // compat with rows installed before the schema change; those rows
  // require a fresh OAuth reconnect to become usable again.
  refreshToken  String?
  expiresAt     DateTime?
  scope         String
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  updatedAt     DateTime  @updatedAt

  interestSignals ShopifyInterestSignal[]
}

// "Notify me when back in stock" interest captured by the agent during
// a conversation. When Shopify's inventory_levels/update webhook fires
// for a matching variant going from 0 → positive, we match interest
// signals and send a proactive DM/widget message back to the customer.
//
// Indexed by (shopId, variantId) so the webhook handler does a single
// lookup per inventory change. `notifiedAt` is set when we send the
// follow-up so the same signal doesn't fire twice on subsequent
// inventory wiggles.
model ShopifyInterestSignal {
  id             String      @id @default(cuid())
  shopId         String
  shop           ShopifyShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  variantId      String
  // The channel + conversation we should DM when stock returns. For
  // MVP we only support widget — Meta/SMS deferred until we wire
  // outbound to those channels.
  channel        String // "widget" for now; "meta" | "sms" later
  // For widget: the WidgetConversation.id. For other channels later:
  // whatever id their outbound API needs.
  conversationId String
  // Display fields captured at the time of interest so we can build a
  // sensible message without re-fetching from Shopify (which might
  // have updated the product since).
  productTitle   String
  variantTitle   String?
  createdAt      DateTime    @default(now())
  notifiedAt     DateTime?

  @@index([shopId, variantId])
  @@index([shopId, notifiedAt])
}

model Location {
  id                    String     @id
  workspaceId           String?
  workspace             Workspace? @relation("WorkspaceLocations", fields: [workspaceId], references: [id], onDelete: Cascade)
  companyId             String
  userId                String
  userType              String
  scope                 String
  accessToken           String
  refreshToken          String
  refreshTokenId        String
  expiresAt             DateTime
  crmProvider           String     @default("ghl")
  installedAt           DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  onboardingCompletedAt DateTime?
  // Set by the refresh-tokens cron when a proactive refresh genuinely
  // fails (invalid_grant / exhausted retries) — i.e. the refresh token
  // is dead and only a reconnect fixes it. Cleared on any successful
  // refresh or fresh OAuth. This is what lets the dashboard banner say
  // "reconnect required" ONLY for genuinely-dead connections instead of
  // false-alarming on tokens that are merely expired and self-healing.
  tokenRefreshFailedAt  DateTime?

  agents                   Agent[]
  messageLogs              MessageLog[]
  users                    UserLocation[]
  conversationStateRecords ConversationStateRecord[]

  @@index([companyId])
  @@index([workspaceId])
}

// AgentFolder — operator-defined grouping for the workspace's agents.
// Same shape and intent as WidgetFolder (further down): once a workspace
// has more than a handful of agents, the flat grid stops scaling, so
// operators bucket them ("Sales", "Support", "Test", per-client folders
// on whitelabel installs, etc).
//
// Deliberately flat — no parentFolderId. The WidgetFolder precedent and
// every operator request so far has been single-level. Nested folders
// would force a drag-target UX that isn't worth the complexity today.
//
// Color is optional and stores either a hex string or a token name —
// the agents list UI can colour the folder chip if set, otherwise it
// falls back to the neutral surface. Same pattern as WidgetFolder.color.
model AgentFolder {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  color       String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  agents      Agent[]

  @@index([workspaceId, order])
}

model Agent {
  id              String       @id @default(cuid())
  workspaceId     String?
  workspace       Workspace?   @relation("WorkspaceAgents", fields: [workspaceId], references: [id], onDelete: Cascade)
  locationId      String
  location        Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  // Optional grouping. Operators can drop agents into folders for
  // organization once they've got more than a handful. SetNull on
  // folder delete so agents survive a folder cleanup — operators
  // expect this and it matches WidgetFolder's contract.
  folderId        String?
  folder          AgentFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  name            String
  systemPrompt    String       @db.Text
  instructions    String?      @db.Text
  // Vocabulary rules — Array<{never: string; sayInstead?: string|null}>.
  // "never" terms are banned from replies; rules WITH sayInstead are
  // additionally HARD-ENFORCED by find-and-replace on the agent's
  // output (lib/agent/vocabulary.ts), because prompt-only bans lose to
  // knowledge passages quoting the term verbatim (the whitelabel
  // "agent keeps saying HighLevel" bug). Supersedes the plain
  // neverSayList; both are merged at runtime for back-compat.
  vocabularyRules Json?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  enabledTools String[] @default(["get_contact_details", "send_reply", "send_sms", "send_email", "update_contact_tags", "remove_contact_tags", "get_opportunities", "move_opportunity_stage", "add_contact_note", "get_available_slots", "book_appointment", "cancel_appointment", "reschedule_appointment", "create_appointment_note", "get_calendar_events", "find_contact_by_email_or_phone", "upsert_contact", "create_task", "add_to_workflow", "remove_from_workflow", "cancel_scheduled_message", "list_contact_conversations", "mark_opportunity_won", "mark_opportunity_lost", "upsert_opportunity", "list_pipelines", "search_shopify_products", "check_shopify_inventory", "lookup_shopify_customer", "check_shopify_order_status", "create_shopify_checkout", "create_shopify_discount", "record_back_in_stock_interest"])
  calendarId   String?

  // ─── Workflow picker ───
  // When add_to_workflow / remove_from_workflow tools are enabled, the user
  // pins which published workflows the agent is allowed to act on. Stored
  // with denormalized names so the agent's tool schema can show them without
  // hitting GHL on every invocation. Empty/null = tool is effectively disabled
  // (we drop it from the published tool list at runtime).
  addToWorkflowsPick      Json? // Array<{ id: string; name: string }>
  removeFromWorkflowsPick Json? // Array<{ id: string; name: string }>

  qualifyingStyle  String  @default("strict") // "strict" | "natural"
  // Behavioral type chosen at creation. "reactive" (default) = diagnose +
  // resolve, no step sequence. "procedural" = walk a defined sequence with
  // progress ("step 2 of 3"). Only procedural agents ever get step framing.
  agentKind        String  @default("reactive") // "reactive" | "procedural"
  // How a procedural agent's steps are authored. Only meaningful when
  // agentKind="procedural". "simple" = written steps; "advanced" = steps +
  // per-answer skip/jump/stop rules.
  procedureMode    String  @default("simple") // "simple" | "advanced"
  fallbackBehavior String  @default("message") // "message" | "transfer" | "message_and_transfer"
  fallbackMessage  String? @db.Text

  /// 'guided' (default) — each tool obeys its 'use when' rule.
  /// 'autonomous' — the agent decides which tools to call freely.
  toolAutonomyMode String @default("guided")

  /// Hard-coded preset id the agent was created/configured with
  /// ('conversational' | 'booking' | 'custom' | null). Templates only —
  /// once applied, config is decoupled from the preset definition.
  presetId String?

  agentPersonaName   String?
  responseLength     ResponseLength @default(MODERATE)
  formalityLevel     FormalityLevel @default(NEUTRAL)
  useEmojis          Boolean        @default(false)
  neverSayList       String[]       @default([])
  simulateTypos      Boolean        @default(false)
  typingDelayEnabled Boolean        @default(false)
  typingDelayMinMs   Int            @default(500)
  typingDelayMaxMs   Int            @default(3000)
  languages          String[]       @default(["en"])

  // ─── Knowledge scope (Phase 2 retrieval) ───
  // Two-part scope so "read everything" is distinct from "read this
  // specific (possibly empty) set":
  //   knowledgeScopeAll = true  → retrieve from EVERY domain in the
  //     workspace, ignoring knowledgeDomainIds (default — backward
  //     compatible with pre-scoping agents).
  //   knowledgeScopeAll = false → retrieve ONLY from knowledgeDomainIds.
  //     An empty list here means the agent reads NO indexed knowledge
  //     (operator explicitly turned every collection off). This is what
  //     lets an operator run one agent on "Product Support", another on
  //     "Legal Docs", and a third on no indexed knowledge at all within
  //     the same workspace.
  // Empty knowledgeDomainIds is no longer overloaded to mean "all" — the
  // scope flag carries that, so deselecting the only collection sticks.
  knowledgeScopeAll  Boolean  @default(true)
  knowledgeDomainIds String[] @default([])

  // ─── Quiet check-in ───
  // When the agent's last message has been sitting unanswered for the
  // stale threshold (~3 min) on a widget conversation, the cron sends
  // ONE brief, in-voice "still around?" nudge. Default on for new
  // agents — most operators want this behaviour and it's bounded by
  // the staleNotifiedAt latch + "already nudged" keyword guard. Set
  // false for agents where check-ins would feel pushy (high-volume
  // support, broadcast follow-ups).
  enableQuietCheckIn Boolean @default(true)

  // ─── Working Hours & Quiet Periods ───
  workingHoursEnabled Boolean  @default(false)
  workingHoursStart   Int      @default(0) // hour 0-23 (contact-local)
  workingHoursEnd     Int      @default(24) // hour 0-24
  workingDays         String[] @default(["mon", "tue", "wed", "thu", "fri", "sat", "sun"])
  timezone            String? // IANA, e.g. "America/New_York"

  // ─── Emergency Pause ───
  isPaused Boolean   @default(false)
  pausedAt DateTime?

  // ─── Approval Queue ───
  requireApproval Boolean @default(false)
  approvalRules   Json? // { lowSentiment: true, firstContact: true, ... }

  // ─── AI Judge ───
  // When approval is required, run a cheap LLM "judge" pass on the draft
  // reply before queuing for a human. SAFE → auto-release; UNSAFE → optionally
  // auto-block; UNCERTAIN → keep in queue for review.
  judgeEnabled      Boolean @default(false)
  judgeModel        String  @default("haiku")
  judgeAutoSend     Boolean @default(true)
  judgeAutoBlock    Boolean @default(false)
  judgeInstructions String? @db.Text

  // Which LLM serves THIS agent's replies (lib/llm registry key):
  // 'auto' (→ DEFAULT_AGENT_MODEL), 'claude-sonnet', 'deepseek-flash', etc.
  // 'auto' default keeps every existing agent on the platform default
  // (Claude) until an operator opts in or the fleet switch is flipped.
  model String @default("auto")

  // ─── Agent context level ───
  // SIMPLE = minimal system prompt (name + tags only).
  // ADVANCED = also loads opportunities (last 2 quarters) + contact custom
  // fields + the agent's businessContext glossary into every turn's system
  // prompt. Heavier on tokens but the agent can reason about commercial
  // context (e.g. a car dealer's vehicle inquiries) without tool calls.
  //
  // Enum values:
  //   'SIMPLE'   — default text agent
  //   'ADVANCED' — text agent + extra context (opportunities + businessContext)
  //   'VOICE'    — voice-first agent. The dashboard renders a different tab
  //                strip (Identity · Voice · Knowledge · Skills · When to run
  //                · Activity), the agent-list shows a 🎤 affordance, and
  //                the wizard at /agents/new/voice creates these. Text-channel
  //                send tools are pre-disabled via the 'voice' preset.
  agentType       String  @default("SIMPLE")
  // Free-text glossary the operator fills once — tells the agent what
  // their custom fields / opportunities represent in their business. Only
  // used when agentType=ADVANCED.
  businessContext String?

  knowledgeEntries     KnowledgeEntry[]
  attachedCollections  AgentCollection[]
  routingRules         RoutingRule[]
  detectionRules       AgentRule[]
  experiments          AgentExperiment[]
  listeningRules       AgentListeningRule[]
  messageLogs          MessageLog[]
  stopConditions       StopCondition[]
  followUpSequences    FollowUpSequence[]
  qualifyingQuestions  QualifyingQuestion[]
  procedureSteps       ProcedureStep[]
  conversationStates   ConversationStateRecord[]
  contactMemories      ContactMemory[]
  conversationMessages ConversationMessage[]
  vapiConfig           VapiConfig?
  // Voice runtime discriminator: 'vapi' (today's telephony pipeline) vs
  // 'gemini' (native speech-to-speech, web + phone). Authoritative for
  // which config table the dashboard + inbound router read. Nullable +
  // defaults to 'vapi' so every existing agent stays on Vapi untouched.
  voiceRuntime         String?                   @default("vapi")
  geminiVoiceConfig    GeminiVoiceConfig?
  channelDeployments   ChannelDeployment[]
  triggers             AgentTrigger[]
  reviews              AgentReview[]
  platformLearnings    PlatformLearning[]
  simulations          Simulation[]

  referenceHealth AgentReferenceHealth[]
  toolConfigs     AgentToolConfig[]
  gateDecisions   ToolGateDecision[]
  nodeLayouts     AgentNodeLayout[]

  /// 'simple' (default — tab IA) | 'advanced' (canvas IA)
  viewMode String @default("simple")

  @@index([locationId, isActive])
  @@index([workspaceId])
}

/// Per-agent node position overrides for the Visual Workflow Canvas
/// (Phase Adv-1). Composite nodeKey — e.g. "tool:book_appointment",
/// "stop:abc123", "channel:SMS", "trigger:def456". One row per
/// dragged node; nodes never dragged stay at their dagre-computed
/// position and have no row.
model AgentNodeLayout {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  nodeKey   String
  x         Float
  y         Float
  updatedAt DateTime @updatedAt

  @@unique([agentId, nodeKey])
  @@index([agentId])
}

model AgentReferenceHealth {
  id            String    @id @default(cuid())
  agentId       String
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  resourceType  String // 'calendar' | 'workflow' | (future)
  resourceId    String
  sourceField   String
  status        String // 'healthy' | 'broken' | 'transient_error'
  lastCheckedAt DateTime
  lastError     String?
  firstBrokenAt DateTime?

  @@unique([agentId, resourceType, resourceId, sourceField])
  @@index([agentId, status])
}

model AgentToolConfig {
  id               String  @id @default(cuid())
  agentId          String
  agent            Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  toolName         String
  enabled          Boolean @default(true)
  useWhen          String?
  onFailure        String  @default("default")
  onFailureMessage String?

  @@unique([agentId, toolName])
  @@index([agentId])
}

/// Workspace-defined preset. Extends the hardcoded registry at
/// lib/agent/presets.ts with user-saved templates ("Save as preset"
/// on the AgentToolRulesEditor). Applied through the same code path
/// as the hardcoded presets — apply-preset endpoint looks up by id in
/// both sources via applyPresetWithWorkspaceLookup.
///
/// toolDeltas is JSON rather than a child table because the array is
/// read-as-a-whole on every apply and never queried piecemeal. Shape
/// matches PresetToolDelta[] in lib/agent/presets.ts.
model WorkspacePreset {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  /// Stored autonomy mode for this preset (mirrors hardcoded preset shape).
  autonomyMode String    @default("guided")
  /// JSON-serialised PresetToolDelta[] — the same shape as the hardcoded
  /// presets at lib/agent/presets.ts. Stored as JSON column rather than
  /// a child table because the array is read-as-a-whole on every apply
  /// and never queried piecemeal.
  toolDeltas   Json      @default("[]")
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([workspaceId])
}

/// Audit log for the enforced-tool gate (Phase B3). One row per gate
/// check on a tool flagged `enforcement: 'enforced'` in the catalog.
/// `decision` is 'allowed' | 'blocked'. Fail-open paths log themselves
/// here too with reason 'gate_failure:...' or 'parse_failure:...'.
model ToolGateDecision {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversationId String?
  contactId      String?
  toolName       String
  decision       String // 'allowed' | 'blocked'
  reason         String?
  latencyMs      Int
  inputTokens    Int?
  outputTokens   Int?
  createdAt      DateTime @default(now())

  @@index([agentId, createdAt])
  @@index([toolName, decision])
}

// Knowledge Collection — the unit operators reason about. A collection
// is a named bundle of items (text entries, file uploads, URL crawls,
// FAQs, Notion pages, YouTube transcripts, AND live data sources)
// that an agent can subscribe to. Agents stack collections, not
// individual items.
model KnowledgeCollection {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation("WorkspaceKnowledgeCollections", fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // Lightweight visual identity for the collection list view. Emoji /
  // hex colour. Both optional; UI falls back to a default.
  icon        String?
  color       String?
  // Display order — lets operators pin "Master FAQs" to the top of the
  // workspace knowledge page. Ascending; equal values sort by createdAt.
  order       Int       @default(0)
  // Whitelabel brand the collection belongs to. Null = workspace-shared
  // (a "Master FAQs" set every brand can use). Set = brand-scoped, so
  // it shows up only when filtering by that brand.
  brandId     String?
  brand       Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  entries     KnowledgeEntry[]
  dataSources WorkspaceDataSource[]
  attachments AgentCollection[]

  @@index([workspaceId, order])
  @@index([brandId])
}

// Junction connecting an agent to a knowledge collection. Single
// source of truth for which collections an agent pulls into its
// system prompt at runtime — both the static knowledge entries and
// the data-source tools live inside the collection.
model AgentCollection {
  id           String              @id @default(cuid())
  agentId      String
  agent        Agent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  collectionId String
  collection   KnowledgeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  attachedAt   DateTime            @default(now())

  @@unique([agentId, collectionId])
  @@index([collectionId])
}

// A single knowledge item (text, FAQ pair, crawled chunk, etc.). Lives
// inside a KnowledgeCollection. The legacy `workspaceId` and `agentId`
// columns are kept temporarily for migration tracking — collectionId is
// the live attachment path.
model KnowledgeEntry {
  id            String              @id @default(cuid())
  collectionId  String
  collection    KnowledgeCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  workspaceId   String
  workspace     Workspace           @relation("WorkspaceKnowledge", fields: [workspaceId], references: [id], onDelete: Cascade)
  // Origin pointer — the agent whose page first created this entry, if
  // any. Pre-collections (legacy). Nullable; not used for routing.
  agentId       String?
  agent         Agent?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  title         String
  content       String              @db.Text
  source        String              @default("manual")
  sourceUrl     String?
  tokenEstimate Int                 @default(0)
  status        String              @default("ready") // "pending" | "indexing" | "ready" | "failed"
  contentHash   String? // for crawl dedupe / change detection
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([collectionId])
  @@index([collectionId, status])
  @@index([workspaceId])
  @@index([agentId])
}

// ─── Phase 2 Knowledge Pipeline ────────────────────────────────────────────
// A KnowledgeDomain sits ABOVE brands. Each workspace can have one or many
// domains (e.g. "Product Support", "Legal", "Coaching"). Retrieval is
// shared WITHIN a domain — brands belong to a domain and benefit from the
// same pool of chunks. Cross-domain retrieval never happens.
//
// The legacy KnowledgeCollection model above remains for backward
// compatibility (text knowledge stuffed into prompts). The chunk-based
// pipeline below is the new path: vector-indexed retrieval against
// crawled / uploaded sources.
model KnowledgeDomain {
  id                String            @id @default(cuid())
  workspaceId       String
  workspace         Workspace         @relation("WorkspaceKnowledgeDomains", fields: [workspaceId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  // Optional brand scope. Set when this domain is a brand's portal-managed
  // knowledge container (created lazily by getOrCreateBrandDomain — one per
  // brand, unique). Null = normal workspace domain. Retrieval stays
  // workspace-scoped either way; the ticket suggest-reply path additionally
  // targets this domain by brand.
  brandId           String?           @unique
  brand             Brand?            @relation("BrandKnowledgeDomain", fields: [brandId], references: [id], onDelete: Cascade)
  // Default intent tags injected when the LLM classifier finds nothing
  // in the per-domain taxonomy. Lets a workspace pre-seed sensible
  // labels ("how_to", "pricing", "troubleshooting"...) without manually
  // creating every taxonomy row up front.
  defaultIntentTags String[]          @default([])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  taxonomies        Taxonomy[]
  sources           KnowledgeSource[]
  chunks            KnowledgeChunk[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

// Per-domain controlled vocabulary. The LLM classifier picks keys
// exclusively from this list during ingest; unmatched content goes
// to the `_other` bucket so a human can review and either add a new
// row or merge into an existing one via aliases.
//
// `taxonomyVersion` bumps when ANY row in the domain's taxonomy
// changes; every chunk records the version it was classified under,
// so a domain rev triggers a re-classification pass on chunks where
// chunk.taxonomyVersion < currentVersion.
model Taxonomy {
  id                String          @id @default(cuid())
  knowledgeDomainId String
  domain            KnowledgeDomain @relation(fields: [knowledgeDomainId], references: [id], onDelete: Cascade)
  // URL-safe stable identifier (e.g. "workflows", "calendars"). The
  // LLM returns these, not the human label.
  key               String
  label             String
  aliases           String[]        @default([])
  // Optional hierarchy. "workflows" might have parent "automation".
  // Surfaced in retrieval as a fallback ("no exact workflow match,
  // try automation chunks").
  parentKey         String?
  taxonomyVersion   Int             @default(1)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([knowledgeDomainId, key])
  @@index([knowledgeDomainId, parentKey])
}

// A crawlable / fetchable source the ingest pipeline pulls from.
// `sourceType` discriminates which SourceAdapter runs at ingest time —
// new source types (Notion, RSS, Zendesk, etc.) drop in as new adapter
// files with no pipeline changes.
model KnowledgeSource {
  id                String           @id @default(cuid())
  knowledgeDomainId String
  domain            KnowledgeDomain  @relation(fields: [knowledgeDomainId], references: [id], onDelete: Cascade)
  sourceType        String // 'docs' | 'pdf' | 'youtube' | 'rss' | 'community' | 'manual'
  // URL for docs/rss/youtube; opaque identifier for hosted PDFs etc.
  urlOrIdentifier   String
  // Adapter-specific config. For docs: { recrawlIntervalDays, includeSubpaths[], excludePatterns[] }.
  // For pdf: { storageKey, originalFilename }. Free-shape per adapter.
  crawlConfig       Json             @default("{}")
  isActive          Boolean          @default(true)
  lastCrawledAt     DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  runs              IngestionRun[]
  chunks            KnowledgeChunk[]

  @@index([knowledgeDomainId, isActive])
  @@index([lastCrawledAt])
}

// One execution of the pipeline against one source. Every run is
// logged so a partial failure leaves a paper trail — the runs viewer
// surfaces error_log JSON to operators for debugging.
model IngestionRun {
  id               String          @id @default(cuid())
  sourceId         String
  source           KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  status           String          @default("running") // 'running' | 'success' | 'partial' | 'failed'
  pagesAttempted   Int             @default(0)
  pagesSucceeded   Int             @default(0)
  chunksCreated    Int             @default(0)
  chunksSuperseded Int             @default(0)
  // Per-page failures collected into a JSON array. Shape:
  // [{ url, stage: 'fetch'|'normalize'|'chunk'|'classify'|'embed'|'write', message, ts }]
  errorLog         Json            @default("[]")

  @@index([sourceId, startedAt(sort: Desc)])
}

// The core retrieval unit. One row per chunk, embedded into pgvector
// for similarity search. `superseded_at` is the soft-delete signal:
// retrieval filters on `WHERE supersededAt IS NULL`, but old rows
// stay around so we can trace how content evolved.
//
// We define the embedding column via raw SQL in the migration since
// Prisma doesn't natively expose pgvector — the column exists in
// the DB but is omitted from this model definition.
model KnowledgeChunk {
  id                String          @id @default(cuid())
  knowledgeDomainId String
  domain            KnowledgeDomain @relation(fields: [knowledgeDomainId], references: [id], onDelete: Cascade)
  sourceId          String
  source            KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  // Optional brand origin — recorded faithfully, IGNORED at retrieval
  // time at launch (single shared pool within a domain). Flips to
  // scoped retrieval when the eval triggers a switch.
  brandIdOrigin     String?
  visibility        String          @default("domain") // 'domain' | 'workspace' | 'brand' | 'agent'

  content          String  @db.Text
  contentHash      String // sha256 over normalized content — dedup + change detection
  sourceUrl        String
  // 'docs' | 'pdf' | 'youtube' | 'rss' | 'community' | 'conversation' | 'manual'
  sourceType       String
  // Identifier scoped within sourceType (e.g. YouTube video id, blog slug,
  // PDF storage key). Combined with sourceType to find sibling chunks.
  sourceIdentifier String?
  chunkIndex       Int // position within source
  totalChunks      Int // for context-window reassembly

  // Per-adapter metadata blob — page_title, breadcrumb_path[],
  // section_heading, section_anchor, page_last_updated for docs;
  // page_number for PDFs; timestamp for YouTube. Schema is loose by
  // design — adapters own the shape; retrieval treats it as opaque.
  sourceMetadata Json @default("{}")

  // Embedding model identifier (e.g. "voyage-3"). Selective re-embed
  // works by filtering this column when a model swap lands.
  embeddingModel String

  // Semantic
  primaryTopic    String?
  taxonomyTags    String[] @default([])
  intentTags      String[] @default([])
  taxonomyVersion Int      @default(1)
  // How many times auto-topics has shown this chunk to the model without
  // managing to tag it. Chunks at the cap count as unclassifiable and are
  // skipped — without this, a bucket of untaggable chunks made the idle
  // backstop burn a Haiku call every minute, forever (Jul 2026).
  autoTopicAttempts Int @default(0)

  // Quality
  confidenceTier String @default("provisional") // 'canonical' | 'provisional' | 'draft'
  qualityScore   Float  @default(0.5)

  // Lifecycle
  createdAt      DateTime  @default(now())
  indexedAt      DateTime  @default(now())
  lastVerifiedAt DateTime  @default(now())
  lastUsedAt     DateTime?
  useCount       Int       @default(0)

  // Versioning chain
  supersedesId       String?
  supersedes         KnowledgeChunk?  @relation("ChunkSupersession", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy       KnowledgeChunk[] @relation("ChunkSupersession")
  supersededAt       DateTime?
  supersessionReason String?
  contentVersion     Int              @default(1)

  // Scoped by sourceId (not just sourceUrl) so the same indexed URL can be
  // CLONED into more than one source/domain — cross-tenant knowledge
  // isolation fix, see prisma/migrations/manual_chunk_unique_per_source.sql.
  @@unique([sourceId, sourceUrl, chunkIndex, contentVersion])
  @@index([knowledgeDomainId, supersededAt])
  @@index([sourceId, supersededAt])
  @@index([contentHash])
  @@index([taxonomyVersion])
  @@index([embeddingModel])
}

// ─── Topic telemetry ───────────────────────────────────────────────────────
// One row per (conversation, topic) the AI agent actually answered from —
// the matched KnowledgeDomain (collection) for a visitor question. Written
// fire-and-forget by the widget runner (lib/agent/capture-topics.ts) and
// aggregated by the customer portal Overview into the "Top topics" panel.
// Standalone (no FK relations) so it can be pruned/backfilled freely and
// never blocks a conversation write.
model ConversationTopic {
  id             String   @id @default(cuid())
  conversationId String
  widgetId       String
  workspaceId    String
  domainId       String? // KnowledgeDomain.id when the match carried one
  topic          String // human-meaningful label (domain name, else primaryTopic)
  createdAt      DateTime @default(now())

  // One row per topic per conversation — repeated hits in the same chat
  // are no-ops (createMany skipDuplicates), so counts = distinct
  // conversations per topic.
  @@unique([conversationId, topic])
  @@index([widgetId, createdAt])
  @@index([workspaceId, createdAt])
}

// ─── Recurring crawl schedule ──────────────────────────────────────────────
model CrawlSchedule {
  id         String    @id @default(cuid())
  agentId    String
  url        String
  frequency  String // "daily" | "weekly" | "monthly"
  isActive   Boolean   @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime
  lastStatus String? // "success" | "failed" | "no_changes"
  lastError  String?   @db.Text
  newChunks  Int       @default(0) // total new chunks across all runs
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([agentId])
  @@index([isActive, nextRunAt])
}

model RoutingRule {
  id       String @id @default(cuid())
  agentId  String
  agent    Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  priority Int    @default(10)

  // Legacy single-condition shape. Kept for back-compat with existing rows.
  // The evaluator falls back to this when `conditions` is null.
  ruleType RuleType
  value    String?

  // Compound condition tree. When present, overrides ruleType/value.
  // Shape: { clauses: [{ ruleType: 'TAG', values: ['a','b'] }, ...] }
  //   - Implicit AND between clauses (all must match for the rule to fire)
  //   - Implicit OR within a clause's `values` (any value matches that clause)
  // Kept as Json so the shape can evolve without further migrations.
  conditions Json?

  // Per-channel scope. Empty array = legacy behaviour (rule applies on
  // every channel the agent is listening on via ChannelDeployment).
  // Non-empty = rule only fires when the inbound channel is in this list.
  // Enables the "All SMS, but only Facebook with tag X" pattern that
  // wasn't expressible when rules were globally scoped.
  channels String[] @default([])

  createdAt DateTime @default(now())

  @@index([agentId, priority])
}

enum RuleType {
  ALL
  TAG
  PIPELINE_STAGE
  KEYWORD
}

// ─── Detection Rules ──────────────────────────────────────────────────────
// User-authored "IF the contact says X, THEN do Y" rules.
// The condition is a natural-language description plus few-shot examples —
// the agent evaluates it semantically against each inbound message.
//
// actionType controls what Y is:
//   update_contact_field (default) → set targetFieldKey to targetValue
//   update_contact_tags            → add tags listed in actionParams.tags
//   remove_contact_tags            → remove tags listed in actionParams.tags
//   add_to_workflow                → enroll in actionParams.workflowIds
//   remove_from_workflow           → remove from actionParams.workflowIds
//   opportunity_status             → set opp status (won/lost/abandoned/open)
//   opportunity_value              → set opp monetaryValue
//   dnd_channel                    → mark DND on actionParams.channel
//
// Legacy rows predate actionType — they have targetFieldKey/targetValue set
// and actionType='update_contact_field' by migration default, so the
// executor can run them unchanged.
model AgentRule {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  name                 String // "Out of town"
  conditionDescription String   @db.Text // "contact indicates they are out of town or traveling"
  examples             String[] @default([]) // few-shot phrases

  // Action. update_contact_field uses the three legacy columns below;
  // every other actionType reads from actionParams.
  actionType   String @default("update_contact_field")
  actionParams Json?

  targetFieldKey String // used by update_contact_field only; empty string otherwise
  targetValue    String // used by update_contact_field only; empty string otherwise
  overwrite      Boolean @default(false)

  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, isActive, order])
}

model MessageLog {
  id               String    @id @default(cuid())
  locationId       String
  location         Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  agentId          String?
  agent            Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  contactId        String
  conversationId   String
  inboundMessage   String    @db.Text
  outboundReply    String?   @db.Text
  actionsPerformed String[]
  tokensUsed       Int       @default(0)
  toolCallTrace    Json?
  status           LogStatus @default(PENDING)
  errorMessage     String?   @db.Text
  createdAt        DateTime  @default(now())

  // ─── Out-of-band model-failure retry (transient provider outages) ───
  // When a reply was skipped by a TRANSIENT model failure (model_unavailable),
  // the row is marked ERROR and modelRetryAt is set to a future time. The
  // retry-model-failures cron replays due rows, re-running the agent on the
  // same prompt and sending on the captured channel. modelRetryAt is cleared
  // when the reply lands, when a human takes over, or when retries are
  // exhausted (operator paged). Permanent failures (model_rejected) leave
  // modelRetryAt null and are paged immediately.
  channel                String? // inbound channel (e.g. "SMS","FB","IG"); where the retried reply is sent
  conversationProviderId String? // CRM conversation provider id needed to send the retried reply
  modelRetryAt           DateTime? // when this errored row is next due for an automatic retry
  modelRetryCount        Int       @default(0)

  // ─── Approval Queue ───
  needsApproval  Boolean @default(false)
  approvalStatus String? // "pending" | "approved" | "rejected" | "auto_sent" | "auto_sent_by_judge" | "rejected_by_judge"

  // ─── AI Judge verdict (when judgeEnabled on the agent) ───
  judgeVerdict                   String? // "safe" | "unsafe" | "uncertain"
  judgeReason                    String?   @db.Text
  judgeModel                     String?
  approvedBy                     String? // userId
  approvedAt                     DateTime?
  approvalReason                 String? // why it was flagged (e.g. "low_sentiment", "first_contact")
  // Channel + conversationProviderId captured at agent-run time so the
  // approval release can send on the same channel the inbound arrived on.
  approvalChannel                String?
  approvalConversationProviderId String?

  // ─── Inline Correction ───
  corrections MessageCorrection[]

  @@index([locationId, createdAt(sort: Desc)])
  @@index([agentId, createdAt(sort: Desc)])
  @@index([needsApproval, approvalStatus])
  // Cron picks due retries: WHERE status='ERROR' AND modelRetryAt <= now().
  @@index([modelRetryAt])
}

enum LogStatus {
  PENDING
  SUCCESS
  ERROR
  SKIPPED
}

model MessageCorrection {
  id               String     @id @default(cuid())
  messageLogId     String
  messageLog       MessageLog @relation(fields: [messageLogId], references: [id], onDelete: Cascade)
  originalText     String     @db.Text
  correctedText    String     @db.Text
  correctedBy      String // userId
  reason           String?    @db.Text // optional note for training
  savedAsKnowledge Boolean    @default(false)
  createdAt        DateTime   @default(now())

  @@index([messageLogId])
  @@index([correctedBy, createdAt(sort: Desc)])
}

// ─── Agent Prompt Versioning ───────────────────────────────────────────────
model AgentPromptVersion {
  id           String   @id @default(cuid())
  agentId      String
  systemPrompt String   @db.Text
  instructions String?  @db.Text
  changeNote   String?  @db.Text
  editedBy     String // userId
  isRollback   Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([agentId, createdAt(sort: Desc)])
}

// ─── Agent Evaluation (Test Suite) ─────────────────────────────────────────
model AgentEvaluation {
  id                  String               @id @default(cuid())
  agentId             String
  name                String
  scenario            String               @db.Text // inbound message to test
  expectedContains    String[]             @default([]) // substrings that SHOULD be in reply
  expectedNotContains String[]             @default([]) // substrings that SHOULD NOT
  expectedTool        String? // specific tool that should be called
  createdAt           DateTime             @default(now())
  runs                AgentEvaluationRun[]

  @@index([agentId])
}

model AgentEvaluationRun {
  id             String          @id @default(cuid())
  evaluationId   String
  evaluation     AgentEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  actualResponse String?         @db.Text
  passed         Boolean
  failureReasons String[]        @default([])
  toolsCalled    String[]        @default([])
  runBy          String // userId
  runAt          DateTime        @default(now())

  @@index([evaluationId, runAt(sort: Desc)])
}

// ─── Agent Goals + Win/Loss ────────────────────────────────────────────────
model AgentGoal {
  id             String           @id @default(cuid())
  agentId        String
  name           String
  goalType       String // "appointment_booked" | "tag_added" | "opportunity_moved" | "custom"
  value          String? // e.g. the tag name or stage name for matching
  isActive       Boolean          @default(true)
  maxTurns       Int? // optional: win only counts if hit within N turns
  // ─── Behavioural (how the agent should pursue the goal) ───
  isPrimary      Boolean          @default(false) // primary objective — pinned to top of system prompt
  priority       Int              @default(10) // lower = more important (secondary objectives)
  aggressiveness String           @default("moderate") // "soft" | "moderate" | "aggressive"
  triggerPhrases String[]         @default([]) // phrases that should immediately pursue this goal
  preferredTool  String? // tool to use when pursuing (e.g. "book_appointment")
  instruction    String?          @db.Text // custom instruction appended to the prompt
  createdAt      DateTime         @default(now())
  events         AgentGoalEvent[]

  @@index([agentId])
  @@index([agentId, isPrimary, priority])
}

model AgentGoalEvent {
  id             String    @id @default(cuid())
  goalId         String
  goal           AgentGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  contactId      String
  conversationId String?
  achievedAt     DateTime  @default(now())
  turnsToAchieve Int?

  @@index([goalId, achievedAt(sort: Desc)])
  @@index([contactId])
}

// ─── Audit Log ─────────────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String // userId who performed the action
  action      String // "agent.paused" | "message.approved" | ...
  targetType  String? // "agent" | "message" | "workspace" | ...
  targetId    String?
  metadata    Json? // free-form context
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
}

// ─── Consent Tracking (TCPA / GDPR) ────────────────────────────────────────
model ContactConsent {
  id          String   @id @default(cuid())
  workspaceId String
  locationId  String
  contactId   String
  channel     String // "SMS" | "Email" | "WhatsApp" | ...
  status      String // "opted_in" | "opted_out" | "unknown"
  source      String? // "manual" | "keyword" | "webform" | ...
  detail      String?  @db.Text // e.g. the keyword that triggered opt-out
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contactId, channel, workspaceId])
  @@index([workspaceId, status])
}

// ─── Live Takeover ─────────────────────────────────────────────────────────
model LiveTakeover {
  id             String    @id @default(cuid())
  agentId        String
  contactId      String
  conversationId String?
  locationId     String
  takenOverBy    String // userId
  reason         String?   @db.Text
  startedAt      DateTime  @default(now())
  endedAt        DateTime?

  @@index([agentId, endedAt])
  @@index([contactId, endedAt])
}

// ─── Webhook Subscriptions ─────────────────────────────────────────────────
model WebhookSubscription {
  id          String            @id @default(cuid())
  workspaceId String
  url         String
  events      String[]          @default([]) // ["message.sent","appointment.booked",...]
  secret      String // for HMAC signing
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deliveries  WebhookDelivery[]

  @@index([workspaceId])
}

model WebhookDelivery {
  id             String              @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  statusCode     Int?
  responseBody   String?             @db.Text
  attempts       Int                 @default(1)
  succeeded      Boolean             @default(false)
  deliveredAt    DateTime            @default(now())

  @@index([subscriptionId, deliveredAt(sort: Desc)])
}

// ─── Agent Templates Marketplace ───────────────────────────────────────────
model AgentTemplate {
  id                        String   @id @default(cuid())
  slug                      String   @unique
  name                      String
  description               String   @db.Text
  category                  String // "sales" | "support" | "real_estate" | ...
  icon                      String   @default("🤖")
  systemPrompt              String   @db.Text
  suggestedTools            String[] @default([])
  suggestedChannels         String[] @default([])
  sampleQualifyingQuestions Json?
  isOfficial                Boolean  @default(false)
  installCount              Int      @default(0)
  createdAt                 DateTime @default(now())

  // ─── Workspace-scoped templates ───
  // null workspaceId = official/global template (seeded by Xovera).
  // non-null = saved by a customer from an existing agent; only visible
  // inside that workspace.
  workspaceId   String?
  workspace     Workspace? @relation("WorkspaceTemplates", fields: [workspaceId], references: [id], onDelete: Cascade)
  // When a workspace user saves an agent as a template we stash the full
  // agent config (persona, working hours, rules, qualifying, knowledge,
  // triggers, follow-ups, stop conditions, voice config) in this JSON
  // blob. The install flow restores every relation from it. Official
  // templates leave this null and rely on the flat systemPrompt +
  // suggestedTools columns above.
  config        Json?
  // Handy back-reference to the agent this template was snapshotted
  // from, so we can show "made from Agent X" in the UI.
  sourceAgentId String?

  @@index([category])
  @@index([workspaceId])
}

// ─── Notification Channels (Slack + Email) ─────────────────────────────────
// ── Workspace data sources ────────────────────────────────────────────────
// Operator-curated handles to live data the agent can query at runtime via
// the lookup_sheet, query_airtable, and fetch_data tools. The agent
// references them by `name`; tool descriptions list the available sources
// + their descriptions so Claude knows when to call which.
// A live data lookup connection (Google Sheets, Airtable, REST). Lives
// inside a KnowledgeCollection now — agents that connect to the
// collection get the data-source tools automatically alongside any
// static knowledge entries in the same collection.
model WorkspaceDataSource {
  id           String               @id @default(cuid())
  workspaceId  String
  // Collection ownership. Required after backfill — every data source
  // belongs to exactly one collection so agents inherit the tool when
  // they attach the collection.
  collectionId String?
  collection   KnowledgeCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  name         String // slug-ish, e.g. "inventory"
  kind         String // "google_sheet" | "airtable" | "rest_get"
  description  String?
  config       Json                 @default("{}") // sheet URL, base ID, table, headers, etc.
  secretEnc    String? // AES-256-GCM (lib/secrets.ts)
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([collectionId])
}

model NotificationChannel {
  id          String   @id @default(cuid())
  workspaceId String
  type        String // "slack" | "email"
  config      Json // { webhookUrl?: string, email?: string }
  events      String[] @default([]) // ["needs_attention","approval_pending",...]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([workspaceId, type])
}

// ── Per-user notification routing ─────────────────────────────────────────
// Lives alongside NotificationChannel. NotificationChannel fans out to a
// shared destination (e.g. a Slack channel, a team@ inbox); these tables
// fan out to *each individual user* per their preferences.

model UserNotificationPreference {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  event       String // e.g. "widget.new_conversation"
  channels    String[] @default([]) // subset of ["email","web_push"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, workspaceId, event])
  @@index([workspaceId, event])
}

model WebPushSubscription {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  endpoint    String   @unique // unique per browser/device
  p256dh      String
  auth        String
  userAgent   String?
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, workspaceId])
}

model StopCondition {
  id                String            @id @default(cuid())
  agentId           String
  agent             Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conditionType     StopConditionType
  value             String?
  pauseAgent        Boolean           @default(true)
  // Side-effect actions that fire when this specific condition trips.
  // All optional; default behaviour (tag needs-attention) is on so
  // operators don't have to opt into surfacing flagged conversations.
  tagNeedsAttention Boolean           @default(true)
  // GHL workflow IDs. When set, the contact is enrolled into / removed
  // from the workflow the moment this condition matches — useful for
  // auto-starting a "hostile customer recovery" sequence or removing
  // someone from a nurture drip the moment they ask to unsubscribe.
  // Requires the workspace to have a GHL connection with workflows.readonly.
  enrollWorkflowId  String?
  removeWorkflowId  String?
  createdAt         DateTime          @default(now())

  @@index([agentId])
}

model FollowUpSequence {
  id           String         @id @default(cuid())
  agentId      String
  agent        Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name         String
  isActive     Boolean        @default(true)
  triggerType  String         @default("always") // "always" | "no_reply" | "keyword" | "agent"
  triggerValue String? // hours for no_reply, comma-sep keywords for keyword, null for agent/always
  steps        FollowUpStep[]
  jobs         FollowUpJob[]
  createdAt    DateTime       @default(now())

  @@index([agentId])
}

model FollowUpStep {
  id         String           @id @default(cuid())
  sequenceId String
  sequence   FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber Int
  delayHours Int
  message    String           @db.Text

  @@index([sequenceId, stepNumber])
}

model FollowUpJob {
  id             String           @id @default(cuid())
  sequenceId     String
  sequence       FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  locationId     String
  contactId      String
  conversationId String?
  channel        String           @default("SMS")
  currentStep    Int              @default(1)
  status         FollowUpStatus   @default(SCHEDULED)
  scheduledAt    DateTime
  lastSentAt     DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime         @default(now())

  @@index([status, scheduledAt])
  @@index([locationId, contactId])
}

model QualifyingQuestion {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  question   String   @db.Text
  fieldKey   String
  required   Boolean  @default(true)
  order      Int      @default(0)
  answerType String   @default("text")
  choices    String[] @default([])

  // ── Conditional action — "if the answer X, then do Y" ─────────────────
  // conditionOp defines what X is. Historical ops (is_yes / is_no / contains
  // / equals / gt / lt / any) still work unchanged. New op:
  //   is_any_of     — answer exactly matches one of `conditionValues` (used
  //                   for multi-choice questions so the user picks allowed
  //                   answers instead of typing a single word).
  conditionOp     String?
  conditionVal    String? // legacy single-value string, kept for back-compat
  conditionValues String[] @default([]) // new: multi-value for is_any_of

  // actionType is the verb. Historical: tag / stage / book / stop / continue.
  // New:
  //   add_to_workflow       — params: { workflowIds: [string], workflowNames: [string] }
  //   remove_from_workflow  — params: { workflowIds: [string], workflowNames: [string] }
  //   opportunity_status    — params: { status: 'won' | 'lost' | 'abandoned' | 'open' }
  //   opportunity_value     — params: { monetaryValue: number }
  //   dnd_channel           — params: { channel?: string }  (defaults to the
  //                           channel the conversation is on)
  actionType   String?
  actionValue  String? // legacy single-string param, kept for back-compat
  actionParams Json? // typed params for newer actions

  crmFieldKey String?
  overwrite   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([agentId, order])
}

model ConversationStateRecord {
  id                 String            @id @default(cuid())
  agentId            String
  agent              Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  locationId         String
  /// Added 2026-05-29 so /needs-attention can read Location.crmProvider
  /// for HandoffAlertBanner deep-link routing. Column already existed;
  /// only the Prisma relation declaration was missing — no SQL needed.
  location           Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  contactId          String
  conversationId     String?
  state              ConversationState @default(ACTIVE)
  messageCount       Int               @default(0)
  pauseReason        String?
  pausedAt           DateTime?
  resumedAt          DateTime?
  qualifyingAnswers  Json?
  // Procedural agents only: which step (0-based order) this conversation is
  // on, and when the procedure completed. Null for reactive agents — there's
  // no counter to surface, which is what keeps step framing out of support.
  procedureStepOrder Int?
  procedureDoneAt    DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([agentId, contactId])
  @@index([locationId, state])
}

/// One step in a procedural agent's sequence. Simple mode uses title +
/// instruction; advanced mode adds an optional question, a field to save the
/// answer to, and answer rules ([{ when, action: "skip"|"jump"|"stop",
/// target? }]) that let a step skip, jump, or stop the procedure.
model ProcedureStep {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  order           Int
  title           String
  instruction     String   @db.Text
  question        String?
  collectFieldKey String?
  rules           Json     @default("[]")
  createdAt       DateTime @default(now())

  @@index([agentId, order])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  locationId     String
  contactId      String
  conversationId String
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  @@index([agentId, contactId, createdAt(sort: Asc)])
  @@index([conversationId, createdAt(sort: Asc)])
}

// ─── Listening Rules ──────────────────────────────────────────────────────
// "IF the contact mentions something in category X, THEN capture it in the
// agent's memory of this contact." Unlike detection rules (AgentRule) which
// write a known value to a known field, listening rules capture free-text
// context the user couldn't have anticipated — family news, health issues,
// personal preferences. The agent writes the content; the user only
// declares what categories are worth listening for.
model AgentListeningRule {
  id      String @id @default(cuid())
  agentId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  name        String // "Family context", "Pain points"
  description String   @db.Text // "family members, health issues, life events"
  examples    String[] @default([]) // illustrative phrases

  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, isActive, order])
}

model ContactMemory {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  locationId String
  contactId  String
  summary    String?  @db.Text // auto-generated conversation summary
  categories Json? // { "Family context": "mum is sick", ... } — keyed by listening rule name
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([agentId, contactId])
}

model AgentTrigger {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  eventType      String // "ContactCreate" | "ContactTagUpdate"
  tagFilter      String? // only fire when this specific tag is present/added
  channel        String   @default("SMS") // which channel to send on: "SMS" | "WhatsApp" | "Email" etc.
  messageMode    String   @default("AI_GENERATE") // "FIXED" | "AI_GENERATE"
  fixedMessage   String?  @db.Text // static first message (when mode=FIXED)
  aiInstructions String?  @db.Text // extra context for the AI (when mode=AI_GENERATE)
  delaySeconds   Int      @default(0) // optional delay before sending (0 = immediate)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agentId])
  @@index([eventType, isActive])
}

model ChannelDeployment {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channel   String // "SMS" | "WhatsApp" | "GMB" | "FB" | "IG" | "Live_Chat" | "Email"
  isActive  Boolean  @default(true)
  config    Json? // channel-specific settings (e.g. WhatsApp template, FB page ID)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, channel])
  @@index([channel, isActive])
}

model VapiConfig {
  id              String   @id @default(cuid())
  agentId         String   @unique
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  phoneNumberId   String?
  phoneNumber     String?
  // Which TTS provider powers this agent's voice. The VoiceAdapter factory
  // keys off this to pick Vapi vs. XAI (or future providers). Vapi is the
  // only provider that can do phone calls today — other providers are
  // browser/widget-only until we ship the Twilio bridge.
  ttsProvider     String   @default("vapi")
  voiceProvider   String   @default("elevenlabs")
  voiceId         String   @default("EXAVITQu4vr4xnSDxMaL")
  voiceName       String?
  stability       Float    @default(0.5)
  similarityBoost Float    @default(0.75)
  speed           Float    @default(1.0)
  style           Float    @default(0.0)
  firstMessage    String?  @db.Text
  endCallMessage  String?  @db.Text
  maxDurationSecs Int      @default(600)
  recordCalls     Boolean  @default(true)
  backgroundSound String?
  endCallPhrases  String[] @default([])
  language        String?
  voiceTools      Json?
  isActive        Boolean  @default(false)
  // Vapi assistant id — the id of the pre-registered assistant in Vapi
  // that browser + phone calls reference by id. Replaces the previous
  // approach of building an inline transient assistant config at every
  // call site (which made shape mismatches fail late as "Meeting ended
  // due to ejection" with no actionable error). When this column is
  // null, the lifecycle code creates the assistant lazily on the next
  // save / call and stores the id here. Unique because Vapi assistant
  // ids are 1:1 with VapiConfig rows.
  vapiAssistantId String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Native Gemini speech-to-speech voice config. Sibling to VapiConfig
// (1:1 on Agent), NOT nullable columns on VapiConfig — VapiConfig is
// Vapi-specific (vapiAssistantId, ElevenLabs tuning). Gemini bypasses
// Vapi entirely. twilioNumber* are reserved for the Plan-2 phone path
// (provisioned via Twilio, not Vapi); the web runtime ignores them.
model GeminiVoiceConfig {
  id              String   @id @default(cuid())
  agentId         String   @unique
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  isActive        Boolean  @default(false)
  // Gemini prebuilt voice id (e.g. 'Puck', 'Kore'). null = model default.
  voiceName       String?
  // Native-audio model id, env-overridable (GEMINI_VOICE_MODEL).
  model           String   @default("gemini-3.1-flash-live")
  firstMessage    String?  @db.Text
  endCallMessage  String?  @db.Text
  maxDurationSecs Int      @default(600)
  recordCalls     Boolean  @default(true)
  language        String?
  // Plan-2 phone path (Twilio carrier — provisioned outside Vapi).
  twilioNumberSid String?
  twilioNumber    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Diagnostic capture for browser test-call failures. The @vapi-ai/web
// daily-co transport reports failures as a generic "Meeting ended due
// to ejection" — useless for debugging. This table stores the full
// error payload posted from the browser when vapi.on('error') fires,
// so the next failure is grep-able server-side instead of lost in the
// user's browser console.
model VoiceTestCallDiagnostic {
  id              String   @id @default(cuid())
  workspaceId     String
  agentId         String
  vapiAssistantId String?
  errorType       String? // 'daily-error' | 'config' | 'permission' | etc.
  errorPayload    Json?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([agentId])
  @@index([workspaceId, createdAt])
}

model CallLog {
  id            String   @id @default(cuid())
  locationId    String
  agentId       String?
  contactId     String?
  contactPhone  String?
  vapiCallId    String?  @unique
  direction     String   @default("inbound")
  status        String   @default("completed")
  durationSecs  Int?
  transcript    String?  @db.Text
  summary       String?  @db.Text
  recordingUrl  String?
  tokensUsed    Int      @default(0)
  endedReason   String?
  triggerSource String?
  createdAt     DateTime @default(now())

  @@index([locationId, createdAt(sort: Desc)])
  @@index([agentId, createdAt(sort: Desc)])
}

model ScheduledMessage {
  id          String    @id @default(cuid())
  locationId  String
  agentId     String?
  contactId   String
  channel     String    @default("SMS")
  message     String    @db.Text
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("pending") // pending, sent, cancelled, failed
  createdAt   DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([locationId, contactId])
}

model LeadScore {
  id         String   @id @default(cuid())
  locationId String
  agentId    String
  contactId  String
  score      Int
  reason     String
  createdAt  DateTime @default(now())

  @@unique([agentId, contactId])
  @@index([locationId, score(sort: Desc)])
}

model MessageBuffer {
  id             String   @id @default(cuid())
  locationId     String
  contactId      String
  conversationId String
  // GHL's webhook-level message ID. Used as the idempotency key for inbound
  // webhooks — GHL retries the same delivery whenever our handler is slow
  // to ack, and the only safe way to suppress those retries is to insert
  // here under a unique constraint and treat the violation as "already seen".
  messageId      String?  @unique
  body           String   @db.Text
  processed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([locationId, contactId, processed, createdAt(sort: Asc)])
}

model Integration {
  id          String   @id @default(cuid())
  locationId  String
  type        String
  name        String
  credentials Json
  config      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locationId, type])
}

// ─── Chat Widgets (Intercom-clone) ──────────────────────────────────────────

model WidgetFolder {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  color       String?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  widgets     ChatWidget[]

  @@index([workspaceId, order])
}

// Brand — represents a client/whitelabel brand that the support team
// works on behalf of. One workspace, many brands (one team handles
// multiple clients). Widgets and Knowledge Collections can be tagged
// to a brand so the inbox can filter, conversations can be exported,
// and knowledge stays cleanly separated per client.
//
// Nullable on the things it tags — a workspace that doesn't run a
// whitelabel agency has no brands and the inbox just shows everything
// without a brand filter.
// Named priority bucket for one or more brands. Operators sort brands
// into groups + give each group a priority number; widgets tagged to
// higher-priority brands jump the inbox queue when humans are needed.
// "All else equally" is the natural fall-through for brands that
// aren't in any group — the inbox treats them as the lowest tier.
model BrandGroup {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation("WorkspaceBrandGroups", fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // Lower number = higher priority. 0 = top of queue. Two groups can
  // share the same priority; same-priority groups break ties by chat
  // recency, never by name or id. The pre-defined "Standard" bucket
  // is conventionally priority 100 so operators have headroom to
  // promote anything above it without renumbering.
  priority    Int       @default(100)
  // Optional accent (#rrggbb) for the inbox chip + brand list pill.
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  brands      Brand[]

  @@unique([workspaceId, name])
  @@index([workspaceId, priority])
}

model Brand {
  id            String                @id @default(cuid())
  workspaceId   String
  workspace     Workspace             @relation("WorkspaceBrands", fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  // URL-safe identifier — used in transcript export filenames and the
  // brand-scoped inbox URL. Lowercase letters/numbers/dashes.
  slug          String
  description   String?
  // When false, widget conversations tagged to this brand skip the AI
  // agent entirely — visitor messages still come through to the inbox
  // for human operators to reply to, but no AI agent runs. Useful for
  // agencies that prefer human-only support for specific clients.
  aiEnabled     Boolean               @default(true)
  // Priority bucket the brand belongs to. Null = no group, treated as
  // the lowest-priority bucket by the inbox sort. SetNull on group
  // delete so brands survive group deletion (they just become
  // ungrouped + drop in priority).
  brandGroupId  String?
  brandGroup    BrandGroup?           @relation(fields: [brandGroupId], references: [id], onDelete: SetNull)
  // Visual identity for the operator inbox: a chip with a colored dot
  // + the brand logo on each conversation row makes routing obvious.
  logoUrl       String?
  primaryColor  String?
  // Optional login URL for this brand's own platform (CRM, dashboard,
  // etc.). Surfaced in the inbox as a quick "Open login" button so
  // agents can jump to the right place fast. Generic — no vendor brand.
  loginUrl      String?
  // Words / phrases the AI must never use when drafting replies for this
  // brand. Maintained by portal users on the portal Knowledge page; applied
  // as a hard prompt rule in ticket suggest-reply plus a post-generation
  // check that warns the composing agent about violations.
  negativeKeywords String[]           @default([])
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  widgets       ChatWidget[]
  collections   KnowledgeCollection[]
  portalAccess  PortalUserBrand[]     @relation("BrandPortalAccess")
  portalCatalog PortalBrand[]         @relation("BrandPortalCatalog")
  tickets       Ticket[]              @relation("TicketBrand")
  knowledgeDomain KnowledgeDomain?    @relation("BrandKnowledgeDomain")
  snippets      BrandSnippet[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([brandGroupId])
}

// Brand-approved reusable blurbs and links — the owner's calendar link,
// support contact details, refund-policy one-liner, etc. Maintained by
// portal users; surfaced to ticketing agents in the compose UI and offered
// to the AI during suggest-reply ("use when clearly relevant, verbatim").
model BrandSnippet {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  title   String
  content String @db.Text
  // 'text' | 'link' — rendering hint for the compose UI; content is
  // canonical either way (a 'link' snippet's content is the URL).
  kind    String @default("text")

  isActive Boolean @default(true)

  // Provenance — exactly one is set depending on which surface created it.
  createdByPortalUserId String?
  createdByUserId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandId, isActive])
}

model ChatWidget {
  id                        String               @id @default(cuid())
  workspaceId               String
  name                      String
  publicKey                 String               @unique
  // Optional grouping. Operators can drop widgets into folders for
  // organization once they've got more than a handful.
  folderId                  String?
  folder                    WidgetFolder?        @relation(fields: [folderId], references: [id], onDelete: SetNull)
  // Whitelabel brand this widget represents. Optional — workspaces
  // that aren't running a multi-brand agency leave this null and the
  // brand UX doesn't show up. SetNull on brand delete so widgets
  // survive (they just go untagged).
  brandId                   String?
  brand                     Brand?               @relation(fields: [brandId], references: [id], onDelete: SetNull)
  // Type — "chat" (full chat UI w/ optional voice) or "click_to_call" (just a styled button that opens a voice call)
  type                      String               @default("chat")
  // Slug — used for hosted call page at /c/{slug}. Optional, unique when set.
  slug                      String?              @unique
  // Embed mode — "floating" (fixed launcher) or "inline" (renders into a target div on the host page)
  embedMode                 String               @default("floating")
  // Appearance
  primaryColor              String               @default("#fa4d2e")
  logoUrl                   String?
  // What the floating launcher bubble shows. "chat" = classic chat-bubble
  // glyph, "question" = a "?" mark, "letter" = launcherLetter (falls back
  // to the title's initial) as a Gmail-style letter mark, "logo" = the
  // uploaded logoUrl image filling the circle.
  launcherIcon              String               @default("chat") // chat | question | letter | logo
  launcherLetter            String?
  title                     String               @default("Chat with us")
  subtitle                  String               @default("We typically reply within a minute")
  welcomeMessage            String               @default("Hi! How can we help?") @db.Text
  position                  String               @default("bottom-right")
  // Click-to-call button styling
  buttonLabel               String               @default("Talk to us")
  buttonShape               String               @default("pill") // pill | rounded | square
  buttonSize                String               @default("md") // sm | md | lg
  buttonIcon                String               @default("phone") // phone | mic | none
  buttonTextColor           String               @default("#ffffff")
  // Hosted call page copy
  hostedPageHeadline        String?
  hostedPageSubtext         String?
  // Identity
  requireEmail              Boolean              @default(false)
  askForNameEmail           Boolean              @default(true)
  // Voice
  voiceEnabled              Boolean              @default(false)
  voiceAgentId              String?
  // Routing
  defaultAgentId            String?
  // Operator assignment routing. Determines who the chat lands on when
  // a human is needed (AI handover, manual takeover). "manual" leaves
  // the conversation unassigned for any operator to claim from the
  // inbox; "round_robin" cycles through the eligible users; "first_available"
  // picks the available user with the fewest open chats.
  routingMode               String               @default("manual") // manual | round_robin | first_available
  // Eligible operator user IDs. Empty array means "all workspace
  // members" — useful so a brand-new widget routes to everyone without
  // explicit configuration.
  routingTargetUserIds      String[]             @default([])
  // Cursor for round-robin so we hand the next chat to the *next* person
  // in the rotation, not the same person every time.
  routingLastAssignedUserId String?
  // Fallback owner for explicit human handoffs. When the customer asks
  // for a human and normal routing finds nobody (manual mode, or
  // everyone is away), the chat force-assigns here so it's never left
  // ownerless. Null = fall back to the workspace owner.
  routingFallbackUserId     String?
  allowedDomains            String[]             @default([])
  // Operator-facing whitelabel / agency URL. Surfaced in the inbox
  // conversation panel as a quick "open the client's site" link so a
  // support rep working many whitelabel brands can jump to the right
  // place. NOT sent to visitors — purely an internal convenience. The
  // page a visitor actually started the chat on is captured separately
  // on WidgetConversation.initiatedUrl.
  agencyUrl                 String?
  // Auto-identify visitors from the CRM dashboard (the marketplace app's
  // injected JS reads the logged-in user). Only meaningful when the
  // widget has an agency connection; ON by default, opt-out per widget.
  autoIdentify              Boolean              @default(true)
  // Launcher options: up to 2 entries offering different kinds of help
  // ("Support" chat agent, "Onboarding" voice agent, live screen-share).
  // JSON: [{ kind: 'chat'|'voice'|'copilot', agentId?, label }]. Null =
  // classic single-agent launcher.
  launcherAgents            Json?
  isActive                  Boolean              @default(true)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  visitors                  WidgetVisitor[]
  conversations             WidgetConversation[]
  agencyConnection          AgencyConnection?

  @@index([workspaceId])
  @@index([folderId])
  @@index([brandId])
}

// Single-use magic link for cross-device chat recovery. Issued when a
// visitor identifies with an email that already exists for this widget
// under a different cookieId AND that prior visitor has a live
// conversation. The visitor clicks the link, the recover endpoint
// re-points the original WidgetVisitor row at the new cookieId, and
// the conversation resumes — no separate verification factor needed
// because email ownership is proved by clicking a link delivered there.
model VisitorRecoveryToken {
  id        String        @id @default(cuid())
  token     String        @unique
  visitorId String
  visitor   WidgetVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  widgetId  String
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([visitorId])
  @@index([expiresAt])
}

model WidgetVisitor {
  id             String                 @id @default(cuid())
  widgetId       String
  widget         ChatWidget             @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  cookieId       String
  email          String?
  name           String?
  phone          String?
  firstSeenAt    DateTime               @default(now())
  lastSeenAt     DateTime               @default(now())
  crmContactId   String?
  userAgent      String?
  ipAddress      String?
  // Coarse geolocation captured from Vercel's edge headers at identify
  // time (city-level, not the raw IP). Powers the portal's global
  // telemetry map. Nullable — backfilled on the visitor's next visit.
  country        String? // ISO-3166-1 alpha-2 (e.g. "US")
  city           String?
  latitude       Float?
  longitude      Float?
  // Convenience: most-recent page the visitor was seen on. Updated by
  // the page_view event ingest. Operators see this in the inbox to
  // know "where on my site is the visitor right now?" without having
  // to walk the full timeline.
  currentUrl     String?
  currentTitle   String?
  conversations  WidgetConversation[]
  events         WidgetVisitorEvent[]
  recoveryTokens VisitorRecoveryToken[]

  @@unique([widgetId, cookieId])
  @@index([widgetId, lastSeenAt])
  @@index([widgetId, email])
}

// Visitor activity stream — page views, identifies, custom events
// emitted by the widget JS on the host page. Powers the "Timeline"
// panel in the inbox sidebar so operators can see where the visitor
// has been before they hit the chat.
model WidgetVisitorEvent {
  id        String        @id @default(cuid())
  visitorId String
  visitor   WidgetVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  // 'page_view' | 'identify' | 'custom' | reserved for future kinds
  kind      String
  // Free-shape JSON for kind-specific fields. For page_view:
  //   { url, title?, referrer?, search? }
  // For identify: { email?, name?, phone? }
  // For custom (future): caller-defined.
  data      Json          @default("{}")
  createdAt DateTime      @default(now())

  @@index([visitorId, createdAt(sort: Desc)])
}

model WidgetConversation {
  id                  String             @id @default(cuid())
  widgetId            String
  widget              ChatWidget         @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  visitorId           String
  visitor             WidgetVisitor      @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  // CRM sub-account the chat originated from (data-location-id on the
  // embed, threaded through the iframe at conversation create). Nullable —
  // plain-site embeds have no location; rows predating capture are null.
  locationId          String?
  agentId             String?
  status              String             @default("active")
  lastMessageAt       DateTime           @default(now())
  // Cron debounce for conversation.stale — set when we've already paged
  // about this thread so we don't notify again until the visitor replies.
  staleNotifiedAt     DateTime?
  // Cron debounce for time-based operator escalation (assigned human hasn't
  // replied to a waiting visitor within LiveChatSettings.escalateAfterMinutes).
  // Stamped when escalated; cleared when the visitor or operator sends next.
  escalatedNotifiedAt DateTime?
  // Visitor satisfaction (1–5 stars). Submitted via the widget's "Rate
  // this chat" control or auto-prompted on Start-new-conversation.
  csatRating          Int?
  csatComment         String?            @db.Text
  csatSubmittedAt     DateTime?
  // Operator assignment. assignedUserId points at WorkspaceMember.userId
  // (the User row), set either by the routing engine on handover or by
  // an operator picking up the chat manually. assignedAt drives SLA /
  // first-response timing on the inbox.
  assignedUserId      String?
  assignedUser        User?              @relation("ConversationAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedAt          DateTime?
  // Why the chat was assigned. "manual", "self" (operator self-assigned
  // by replying), "round_robin", "first_available". Useful in the inbox
  // and for debugging routing.
  assignmentReason    String?
  // Set when the chat is waiting in the human queue (team at capacity).
  // "In the queue" = queuedAt != null AND assignedUserId == null AND
  // status != 'ended'. Cleared when a human is assigned. Queue order is
  // queuedAt ascending. See lib/widget-routing.ts advanceQueue().
  queuedAt            DateTime?
  // Where on the host site the visitor first opened this chat. Captured
  // at conversation-create time from the widget's window.location, then
  // never updated — distinct from WidgetVisitor.currentUrl, which tracks
  // the visitor as they browse. Operators use this to know "was this
  // chat started on the pricing page or the docs?".
  initiatedUrl        String?
  initiatedTitle      String?
  // Cached Haiku-generated summary of the conversation. Computed on
  // demand (Generate button in the inbox) so we don't run Haiku on
  // every chat. Cleared by clients on stale + regenerated when the
  // conversation has grown materially since aiSummaryAt.
  aiSummary           String?            @db.Text
  aiSummaryAt         DateTime?
  // Set when this conversation was merged INTO another one (the visitor
  // returned in a new session with the same issue and an operator
  // combined the threads). Points at the surviving target conversation.
  // The source's messages are moved onto the target and the source is
  // marked status='ended' + mergedIntoId set, so the inbox can quietly
  // redirect anyone who opens it to the merged thread instead of
  // showing a now-empty husk.
  mergedIntoId        String?
  createdAt           DateTime           @default(now())
  messages            WidgetMessage[]
  notes               ConversationNote[]
  voiceCalls          WidgetVoiceCall[]
  // Conversation promoted into a ticket (1:0..1). Back-relation for
  // Ticket.conversation. SetNull on the Ticket side means the ticket
  // survives if the source convo is hard-deleted.
  ticket              Ticket?            @relation("ConversationTicket")

  @@index([widgetId, lastMessageAt(sort: Desc)])
  @@index([widgetId, locationId])
  @@index([visitorId])
  @@index([agentId, status])
  @@index([assignedUserId, status])
  @@index([queuedAt])
}

/// Internal operator note on a live-chat conversation. Deliberately a
/// SEPARATE table from WidgetMessage so the visitor can NEVER receive
/// one through any message-read path (history load, SSE backfill, email
/// transcript all query WidgetMessage only). The operator inbox merges
/// notes into the thread by timestamp; the live SSE event is gated out
/// of the visitor stream.
model ConversationNote {
  id               String             @id @default(cuid())
  conversationId   String
  conversation     WidgetConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorUserId     String?
  author           User?              @relation("ConversationNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  body             String             @db.Text
  // Workspace member user IDs @mentioned in this note; each is notified.
  mentionedUserIds String[]           @default([])
  createdAt        DateTime           @default(now())

  @@index([conversationId, createdAt])
}

model WidgetMessage {
  id             String             @id @default(cuid())
  conversationId String
  conversation   WidgetConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  // Set when a human operator (not the AI agent) sent this outbound message
  // from the dashboard inbox. Null for AI-agent replies and visitor messages.
  // Mirrors MetaMessage.sentByUserId — lets the inbox distinguish "AI" vs a
  // human reply without a new role value (role stays 'agent' for both, so
  // transcript/export/CRM-sync consumers are unaffected).
  sentByUserId   String?
  content        String             @db.Text
  kind           String             @default("text")
  // Detected language (ISO 639-1) of the message content. Null until
  // the async detector lands. Populated by lib/widget-translation.ts
  // shortly after the message is persisted.
  language       String?
  // English translation when language != 'en'. Null when the message
  // is already English or when detection failed. Operators see this
  // rendered below the original in the inbox so they can read what
  // the agent said in Spanish / French / Portuguese / etc.
  translationEn  String?            @db.Text
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt(sort: Asc)])
}

model WidgetVoiceCall {
  id             String             @id @default(cuid())
  conversationId String
  conversation   WidgetConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  vapiCallId     String?
  status         String             @default("requested")
  startedAt      DateTime           @default(now())
  endedAt        DateTime?
  durationSecs   Int?
  transcript     String?            @db.Text

  @@index([conversationId])
}

// ─── MCP Connectors ──────────────────────────────────────────────────────
// External MCP servers attached to a workspace. Per-agent attachments are
// in AgentMcpTool — that's where "when to use this" rules live.

model McpServer {
  id               String         @id @default(cuid())
  workspaceId      String
  name             String
  registrySlug     String? // null for custom; e.g. "meta-ads", "stripe", "linear"
  description      String?
  iconUrl          String?
  transport        String         @default("http") // http | sse
  url              String
  authType         String         @default("bearer") // bearer | header | none
  authSecretEnc    String? // AES-256-GCM ciphertext (see lib/secrets.ts)
  headers          Json? // extra static headers
  isActive         Boolean        @default(true)
  lastDiscoveredAt DateTime?
  discoveredTools  Json? // cached tool list from last discovery
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  agentTools       AgentMcpTool[]

  @@index([workspaceId])
}

model AgentMcpTool {
  id                  String    @id @default(cuid())
  agentId             String
  mcpServerId         String
  mcpServer           McpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  toolName            String
  enabled             Boolean   @default(true)
  whenToUse           String?   @db.Text
  mustIncludeKeywords String[]  @default([])
  requireApproval     Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([agentId, mcpServerId, toolName])
  @@index([agentId])
}

// ─── Agent Self-Experimentation ──────────────────────────────────────────
// A/B test opening lines, personas, or appended instructions on a slice of
// inbounds. The weekly proposer cron writes drafts; an operator approves
// them; runtime hashes contactId to deterministically bucket A vs B and
// records exposure/conversion against AgentGoalEvent.

model AgentExperiment {
  id             String                 @id @default(cuid())
  agentId        String
  agent          Agent                  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  hypothesis     String                 @db.Text
  variantALabel  String                 @default("control")
  variantBLabel  String                 @default("variant-b")
  variantAPrompt String?                @db.Text // appended to system prompt for A; null = vanilla
  variantBPrompt String                 @db.Text
  metric         String                 @default("any_goal") // "any_goal" | "appointment_booked" | "tag_added:<value>"
  splitPercent   Int                    @default(50) // % routed to variant B
  status         String                 @default("draft") // "draft" | "approved" | "running" | "ended" | "rejected"
  proposedBy     String? // "ai" | operator email
  proposedAt     DateTime               @default(now())
  approvedBy     String?
  approvedAt     DateTime?
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  events         AgentExperimentEvent[]

  @@index([agentId, status])
}

model AgentExperimentEvent {
  id           String          @id @default(cuid())
  experimentId String
  experiment   AgentExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  contactId    String
  variant      String // 'A' | 'B'
  outcome      String // 'exposed' | 'converted'
  goalEventId  String?
  createdAt    DateTime        @default(now())

  @@unique([experimentId, contactId, outcome])
  @@index([experimentId, variant, outcome])
}

// ─── Help Center ─────────────────────────────────────────────────────────
// Public, crawlable help articles. Authored by super-admins (emails ending
// in @xovera.io). No per-workspace scoping — the help center is
// product-global, served at /help and indexable.
model HelpCategory {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String?
  icon        String? // emoji or icon key
  order       Int           @default(0)
  articles    HelpArticle[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([order])
}

model HelpArticle {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  summary     String?       @db.Text
  body        String        @db.Text // markdown
  videoUrl    String? // YouTube / Vimeo / mp4
  categoryId  String?
  category    HelpCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  status      String        @default("draft") // "draft" | "published"
  publishedAt DateTime?
  authorEmail String? // whoever last saved it
  order       Int           @default(0)
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId, order])
  @@index([status, publishedAt])
}

// ─── Super-admin backend ──────────────────────────────────────────────────
//
// The /admin area is the software-company cockpit — cross-workspace visibility
// into users, logs, and usage, plus CSV / webhook export for support and
// billing investigations. Separate auth path (Credentials provider) so admins
// don't need OAuth to troubleshoot, and a dedicated table so the allowlist
// lives in the DB rather than env vars (which are harder to rotate safely).

model SuperAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  // bcrypt hash. Raw passwords never hit the DB. See scripts/create-admin.mjs
  // for the bootstrap flow.
  passwordHash String
  name         String?
  // null until first login. Used by the admin dashboard to spot stale
  // accounts and by the CLI to detect "has this admin ever logged in?".
  lastLoginAt  DateTime?
  // Defaults true; set false to revoke without deleting (preserves audit
  // trail that references this row).
  isActive     Boolean   @default(true)

  // ─── Role levels ─────────────────────────────────────────────────
  // "viewer" — read-only: browse every page, no exports/webhooks/admin-mgmt
  // "admin"  — everything except managing other admins + system settings
  // "super"  — god mode: create/disable admins, edit settings
  // First-setup admin is always promoted to "super" so someone has the keys.
  role String @default("admin")

  // ─── TOTP 2FA ────────────────────────────────────────────────────
  // Secret is stored raw (base32). It's protected by the app DB and is
  // only meaningful alongside a valid password, so encrypting-at-app
  // buys little over DB-at-rest encryption.
  twoFactorSecret     String?
  // Set once the admin confirms the enrollment code. Presence of this
  // timestamp is the "2FA required on login" flag.
  twoFactorVerifiedAt DateTime?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  auditLogs    AdminAuditLog[]
  agentReviews AgentReview[]

  @@index([email])
}

// Meta-Claude review thread: an admin opens a specific (agent, contact)
// conversation and chats with a reviewer Claude about what the agent did
// wrong and how to fix it. Each row is ONE review thread; messages
// accumulate in the JSON column as the thread progresses. Kept forever —
// these are training signal, not disposable chat logs.
model AgentReview {
  id             String             @id @default(cuid())
  agentId        String
  agent          Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // The conversation under review is addressed by (agentId + contactId +
  // conversationId). We store all three so the thread survives even if
  // the ConversationMessage rows are later pruned.
  contactId      String
  conversationId String?
  adminId        String?
  admin          SuperAdmin?        @relation(fields: [adminId], references: [id], onDelete: SetNull)
  adminEmail     String // denormalised for audit
  // Short auto-title derived from the first admin message. Surfaced in
  // the reviews list so operators can scan past sessions quickly.
  title          String?
  // [{ role: "admin" | "assistant", content: string, at: ISOString }]
  // Append-only from the app's perspective — new turns push onto the end.
  messages       Json               @default("[]")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  learnings      PlatformLearning[]

  @@index([agentId, createdAt(sort: Desc)])
  @@index([contactId, createdAt(sort: Desc)])
  @@index([adminId, createdAt(sort: Desc)])
}

// Concrete, apply-able suggestion proposed by the meta-Claude reviewer
// during an AgentReview. Lifecycle:
//   proposed  → admin sees it as a card under the reviewer's prose
//   approved  → admin clicked Approve; now eligible for Apply
//   applied   → the change is live on the target agent
//   rejected  → admin killed it; kept for audit
//   retired   → was applied, then rolled back
//
// PR 1: scope is always "this_agent" and type is always "prompt_addition".
// Schema leaves room for scope=workspace|all_agents|new_agents_only and
// type=detection_rule|listening_rule in PR 2 without a migration.
model PlatformLearning {
  id             String       @id @default(cuid())
  // Traceability — every learning points back to the review turn that
  // produced it. Null if the source review was deleted.
  sourceReviewId String?
  sourceReview   AgentReview? @relation(fields: [sourceReviewId], references: [id], onDelete: SetNull)

  // scope controls where this guidance gets applied:
  //   this_agent   — mutates the single target agent's systemPrompt
  //                  (markers-based fence; apply writes, retire strips)
  //   workspace    — ALL agents in the target workspace see it at
  //                  runtime via buildSystemPrompt's platform-guidelines
  //                  block. No agent.systemPrompt mutation.
  //   all_agents   — every agent in every workspace sees it at runtime,
  //                  except workspaces that set disableGlobalLearnings.
  scope       String  @default("this_agent")
  // Populated for this_agent (derived from the agent's workspace) and
  // workspace scopes. Null for all_agents. Enables queries like
  // "give me every applied learning that affects workspace X".
  workspaceId String?
  agentId     String? // required when scope=this_agent
  agent       Agent?  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  type      String // "prompt_addition" (PR 2: detection_rule | listening_rule)
  title     String // short label for the approval queue
  content   String  @db.Text // the actual guidance text
  rationale String? @db.Text // why the reviewer suggested it

  status String @default("proposed") // proposed | approved | applied | rejected | retired

  proposedByEmail String // denormalised admin email (null-safe if admin deleted)
  approvedByEmail String?
  rejectedByEmail String?
  rejectedReason  String?

  appliedAt     DateTime?
  // When status=applied, points to the surface that was changed. For
  // prompt_addition, always "agent.systemPrompt" — the content is
  // fenced in the prompt with marker comments keyed by this learning's
  // id, so Retire is a string-replace op.
  appliedTarget String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([sourceReviewId])
  // Hot path for buildSystemPrompt — pull every applied global/workspace
  // learning quickly without a table scan.
  @@index([scope, status])
  @@index([workspaceId, status])
}

// A synthetic conversation between a "persona Claude" (pretending to be
// a customer with a given context + style) and the real agent running
// via runAgent(sandbox=true). The goal is to generate training signal
// without waiting for real inbounds. After completion, an auto-reviewer
// analyses the transcript and proposes PlatformLearnings that land in
// the /admin/learnings queue waiting for approval.
//
// Lifecycle: queued → running → complete | failed. A cron worker picks
// up queued sims one-per-minute. Manual (synchronous) runs skip the
// queue and go straight to running.
model Simulation {
  id          String  @id @default(cuid())
  // Target agent under test
  agentId     String
  agent       Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // Denormalised workspace for cross-workspace admin queries + auth scoping
  workspaceId String?

  // ─── Persona configuration ───
  // Free-text description of who the simulated contact is + what they
  // want. The persona-Claude reads this at turn 0 and stays in character.
  personaContext String  @db.Text
  // Which channel the simulation pretends to run on. Affects tone +
  // runAgent's internal channel-specific behaviour.
  channel        String // "SMS" | "Email" | "WhatsApp" | "Live_Chat"
  // Communication style: affects the persona-Claude's prompt. Enum-ish
  // but stored as string so we can add new styles without a migration.
  style          String // "friendly" | "aggressive" | "passive" | "skeptical" | "confused" | "ready_to_buy" | "price_shopper"
  // Optional: what the simulated contact is trying to achieve or what
  // behaviour the operator is testing ("try to get them to cancel").
  goal           String? @db.Text
  // Turn ceiling so a persona-agent loop can't run forever.
  maxTurns       Int     @default(10)

  // ─── Execution state ───
  status       String    @default("queued") // queued | running | complete | failed
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?   @db.Text

  // ─── Results ───
  turnCount  Int  @default(0)
  // Array<{ role: "persona" | "agent", content: string, at: ISOString,
  //         toolCalls?: Array<{tool, input, output}> }>
  transcript Json @default("[]")

  // Auto-review linkage. After the sim completes, we invoke the
  // meta-Claude reviewer headlessly and store the resulting review id
  // here. reviewId is null if the auto-review hasn't run yet or failed.
  reviewId               String?
  proposedLearningsCount Int     @default(0)

  // ─── Provenance ───
  createdByType  String // "user" | "admin" | "swarm"
  createdByEmail String? // null when swarm-driven
  swarmId        String?
  swarm          SimulationSwarm? @relation(fields: [swarmId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId, createdAt(sort: Desc)])
  @@index([workspaceId, status])
  // Cron worker hot path — "give me the oldest queued sim".
  @@index([status, createdAt])
  @@index([swarmId])
}

// Admin-only: a batch of simulations configured as matrix of agents ×
// personas. Creates N Simulation rows with status=queued; the cron
// worker picks them up in order. "Run 5 sims per agent across these 3
// agents using these 4 personas" = 60 sims queued.
model SimulationSwarm {
  id              String   @id @default(cuid())
  name            String
  // Customer swarms are scoped to one workspace (one agent × N personas).
  // Admin-driven platform swarms span workspaces and leave this null.
  // The workspace dashboard lists only its own swarms; admin lists all.
  workspaceId     String?
  // Which agents to run against. Stored as IDs so swarms survive agent
  // renames; if an agent is deleted its queued sims fail gracefully.
  agentIds        String[]
  // Array<{ context: string, channel: string, style: string, goal?: string, maxTurns?: number }>
  personaProfiles Json
  runsPerAgent    Int      @default(1)

  status         String @default("queued") // queued | running | complete
  createdByEmail String

  // Precomputed at create time so the progress bar has a denominator
  // even before any simulation starts.
  totalPlanned  Int
  totalComplete Int @default(0)
  totalFailed   Int @default(0)

  simulations Simulation[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([workspaceId, createdAt(sort: Desc)])
}

// System-wide config the admin UI owns. Typed as JSON so we can add new
// keys without a migration. Current keys:
//   auditRetentionDays: number   (null/absent = keep forever)
// The /api/cron/prune-audit-log route reads this every run.
model SystemSetting {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// Audit trail for every meaningful admin action. Growing this catches
// two classes of problem: (a) an ops teammate exported data they
// shouldn't have, (b) debugging "who paused that workspace at 2am?".
// Never pruned automatically — retention is a policy call, not a default.
model AdminAuditLog {
  id         String      @id @default(cuid())
  adminId    String?
  admin      SuperAdmin? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  adminEmail String // denormalised so deletes don't lose context
  action     String // e.g. "login", "export_users_csv", "fire_webhook"
  target     String? // workspaceId / userId / "all" / etc.
  meta       Json? // arbitrary context (row count, filter, url)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// Messenger + Instagram Direct conversations. First-class so the
// unified inbox can render them next to widget chats with the same
// assignment / status / lastMessageAt semantics. Channel-specific
// fields (page, sender PSID/IGSID) live here rather than being
// folded into WidgetConversation, which keeps widget's brand/visitor
// graph untouched.
model MetaConversation {
  id                      String        @id @default(cuid())
  workspaceId             String
  locationId              String
  channel                 String // 'messenger' | 'instagram'
  pageId                  String // entry.id from webhook (Page or IG-Business id)
  pageName                String?
  senderId                String // PSID for Messenger, IGSID for Instagram
  senderName              String?
  senderProfilePicUrl     String?
  agentId                 String?
  status                  String        @default("active")
  lastMessageAt           DateTime      @default(now())
  lastMessagePreview      String?
  lastMessageDirection    String? // 'in' | 'out'
  // Denormalized operator id of the last outbound message, so the inbox
  // list can show "AI" vs a human reply without joining MetaMessage.
  // Null when the last outbound was an AI reply (or last message inbound).
  lastMessageSentByUserId String?
  unreadCount             Int           @default(0)
  assignedUserId          String?
  assignedUser            User?         @relation("MetaConversationAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedAt              DateTime?
  assignmentReason        String?
  createdAt               DateTime      @default(now())
  messages                MetaMessage[]

  // (page, sender, channel) is a single conversation. Same FB user
  // could DM both your Page (Messenger) and your IG account — those
  // are separate threads.
  @@unique([pageId, senderId, channel])
  @@index([workspaceId, lastMessageAt(sort: Desc)])
  @@index([locationId])
  @@index([assignedUserId, status])
}

model MetaMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   MetaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      String // 'in' (end user → us) | 'out' (agent/operator → end user)
  text           String?
  // Meta's message id (mid). Used to dedupe webhook retries on inbound.
  // Outbound messages may not have one (Send API doesn't always return
  // an mid), hence nullable + partial unique index.
  mid            String?
  sentByUserId   String? // non-null when an operator typed the reply
  sentByUser     User?            @relation("MetaMessageAuthor", fields: [sentByUserId], references: [id], onDelete: SetNull)
  metadata       Json? // attachments, postback payload, raw event for debugging
  createdAt      DateTime         @default(now())

  @@unique([mid])
  @@index([conversationId, createdAt])
}

// ─── Customer Portals ─────────────────────────────────────────────────────
//
// A Portal is a read-only view onto a workspace's conversations, scoped to
// a subset of brands. The agency creates portals from /admin and invites
// their *customers* (e.g. each whitelabel client) to log in. Portal users
// only ever see WidgetConversations whose widget.brandId is in the brand
// assignment set for that user.
//
// Auth is deliberately separate from NextAuth (workspace operators) and
// from SuperAdmin (us). See lib/portal-auth.ts for the rationale —
// shorthand: separate cookie, separate session table, separate password
// hash, no cross-pollination of access between the three roles.

model Portal {
  id               String         @id @default(cuid())
  // A portal is a named set of brands (PortalBrand) + its users. It is
  // NOT scoped to a workspace — brands carry their own workspace, and a
  // portal may expose brands from any of them.
  name             String
  // URL-safe identifier for the portal-facing pages (e.g. /portal/login
  // shows the right branding when ?p=<slug> is set, and the slug is the
  // human-friendly handle in the admin list). Lowercase letters/digits/dashes.
  slug             String         @unique
  // Whitelabel host (e.g. "support.acme.com"). When set, requests on
  // this host are routed to the portal and branded as it. Null = the
  // portal is reached via the primary app host only. Manual domain ops:
  // the operator adds the domain to Vercel; the customer points a CNAME.
  customDomain     String?        @unique
  // Optional branding override for the portal login + header. When unset
  // we fall back to plain "Customer Portal" styling.
  logoUrl          String?
  primaryColor     String?
  isActive         Boolean        @default(true)
  // Scheduled email reports to portal users: 'off' | 'daily' | 'weekly'.
  // Settable from BOTH the super-admin portal page and the portal's own
  // settings. reportLastSentAt drives the hourly cron's due-check.
  reportFrequency  String         @default("weekly")
  reportLastSentAt DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  users            PortalUser[]
  invites          PortalInvite[]
  portalBrands     PortalBrand[]
  insight          PortalInsight?
}

model PortalBrand {
  id        String   @id @default(cuid())
  portalId  String
  portal    Portal   @relation(fields: [portalId], references: [id], onDelete: Cascade)
  brandId   String
  brand     Brand    @relation("BrandPortalCatalog", fields: [brandId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([portalId, brandId])
  @@index([brandId])
}

model PortalUser {
  id               String            @id @default(cuid())
  portalId         String
  portal           Portal            @relation(fields: [portalId], references: [id], onDelete: Cascade)
  email            String
  name             String?
  // Null until the user accepts their invite and sets a password. Until
  // then they can log in only via the invite link.
  passwordHash     String?
  isActive         Boolean           @default(true)
  // Include this user in the portal's scheduled email reports. Everyone
  // is on by default; the Email reports card lets any portal user (or an
  // admin in preview) exclude individuals.
  receiveReports   Boolean           @default(true)
  lastLoginAt      DateTime?
  invitedAt        DateTime          @default(now())
  acceptedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  brandAssignments PortalUserBrand[]
  draftReviews     TicketReplyDraft[] @relation("TicketDraftReviewer")

  @@unique([portalId, email])
  @@index([email])
}

model PortalUserBrand {
  id           String     @id @default(cuid())
  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  brandId      String
  brand        Brand      @relation("BrandPortalAccess", fields: [brandId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([portalUserId, brandId])
  @@index([brandId])
}

model PortalInvite {
  id         String    @id @default(cuid())
  portalId   String
  portal     Portal    @relation(fields: [portalId], references: [id], onDelete: Cascade)
  email      String
  // sha256 of the random token sent via email. We never store the raw
  // token — losing the DB doesn't leak active invites, and an attacker
  // who steals a backup can't impersonate pending users.
  tokenHash  String    @unique
  // Brand IDs the inviting admin chose up-front. Materialized into
  // PortalUserBrand rows on accept; kept here so the operator can review
  // pending invites in the admin UI.
  brandIds   String[]  @default([])
  // SuperAdmin.id of the inviter. Useful for audit + "who let this
  // person in" forensics; nullable so a deleted admin doesn't break
  // historical invites.
  invitedBy  String?
  acceptedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@unique([portalId, email])
  @@index([email])
}

// ─── Native CRM ──────────────────────────────────────────────────────────
// Built-in contacts/lists/messaging for workspaces that don't connect an
// external CRM. Each table is workspace-scoped — the Location row is just
// a placeholder (`native:<workspaceId>`) kept so Agent.locationId still
// resolves through the same factory path as GHL/HubSpot.

model NativeContact {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  firstName String?
  lastName  String?
  email     String? // stored lowercased — normalize on write
  phone     String? // stored E.164 — normalize on write
  tags      String[] @default([])
  source    String? // free-form: "csv-import", "widget", "manual", "funnel", etc.

  // { fieldKey: string|number|boolean|string[] } — keys must match an
  // existing NativeCustomField.fieldKey for the workspace.
  customFields Json?

  // Workspace member the contact is "owned" by — drives merge fields like
  // {{user.name}} the same way GHL contacts have an assigned user.
  assignedToUserId String?

  // Set when this contact has opted out via STOP/unsubscribe. The
  // suppression list is the source of truth for sends; this flag is a fast
  // read-side hint so list views can show the badge without joining.
  isSuppressed Boolean @default(false)

  // ─── Xovera funnel attribution ───
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listMemberships NativeContactListMember[]
  conversations   NativeConversation[]
  messages        NativeMessage[]

  @@index([workspaceId, email])
  @@index([workspaceId, phone])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, isSuppressed])
}

// Static or smart segment of contacts. Static lists own their members via
// NativeContactListMember; smart lists store a JSON filter and resolve at
// read time (smart support is a follow-up — for now `type='static'` is
// the only fully-implemented mode).
model NativeContactList {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        String  @default("static") // "static" | "smart"
  filter      Json? // smart-list query, ignored when type='static'

  createdBy String? // userId who created the list
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members NativeContactListMember[]
  imports NativeContactImport[]

  @@unique([workspaceId, name])
  @@index([workspaceId, createdAt(sort: Desc)])
}

model NativeContactListMember {
  id        String            @id @default(cuid())
  listId    String
  list      NativeContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contactId String
  contact   NativeContact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  addedAt   DateTime          @default(now())

  @@unique([listId, contactId])
  @@index([contactId])
}

// CSV import job. Rows are parsed by the upload route and handed to
// processNativeImport(); per-row errors land in NativeContactImportRow so
// the operator can fix and re-upload just the rejected rows.
model NativeContactImport {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  filename String
  status   String @default("pending") // "pending" | "processing" | "completed" | "failed"

  totalRows     Int @default(0)
  importedCount Int @default(0)
  skippedCount  Int @default(0) // duplicates / suppressed / no email+phone
  errorCount    Int @default(0)

  // { csvHeader: string, contactField: string }[] — captured so re-imports
  // of the same file shape can skip the mapping step.
  columnMapping Json?

  // Optional list to add every successfully imported contact to. Cleared
  // on the import row when the list is deleted.
  listId String?
  list   NativeContactList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  createdBy   String? // userId who triggered the import
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  errorRows NativeContactImportRow[]

  @@index([workspaceId, createdAt(sort: Desc)])
}

model NativeContactImportRow {
  id        String              @id @default(cuid())
  importId  String
  import    NativeContactImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowNumber Int
  rawData   Json // the original row, so the operator can fix and re-import
  error     String              @db.Text
  createdAt DateTime            @default(now())

  @@index([importId, rowNumber])
}

// Suppression list — workspace-wide opt-outs. Checked at send time and
// at import time. Phone values are E.164; email values are lowercased.
model NativeSuppression {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  type      String // "email" | "phone"
  value     String // lowercased email or E.164 phone
  reason    String? // "stop_reply" | "manual" | "bounce" | "complaint" | free-form
  createdAt DateTime @default(now())

  @@unique([workspaceId, type, value])
  @@index([workspaceId, type])
}

model NativeConversation {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId   String
  contact     NativeContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  channel       String // "sms" | "email" | "whatsapp" | "voice" | "widget" | "custom"
  unreadCount   Int       @default(0)
  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages NativeMessage[]

  @@index([workspaceId, contactId])
  @@index([workspaceId, lastMessageAt(sort: Desc)])
  @@index([contactId, channel])
}

model NativeMessage {
  id             String             @id @default(cuid())
  workspaceId    String
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   NativeConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contactId      String
  contact        NativeContact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  direction String // "inbound" | "outbound"
  channel   String // mirrors NativeConversation.channel
  body      String  @db.Text
  subject   String? // email only

  // queued = persisted but not yet handed to a delivery rail.
  // sent/delivered/failed are set by the rail callback (Twilio webhook etc.).
  // received = inbound message ingested from a webhook.
  status String @default("queued")

  // ID returned by the underlying sender (Twilio sid, SMTP message-id, etc.)
  // so we can correlate webhooks back to this row.
  providerMessageId String?
  providerError     String? @db.Text

  // Optional attachment metadata for multimodal inbound messages, mirroring
  // the Message type in @/types so the agent's getMessages() output is uniform.
  attachmentKind String?
  attachmentUrl  String?
  attachmentName String?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([contactId, createdAt(sort: Desc)])
}

// Workspace-defined custom fields. The agent's getCustomFields() reads
// these so prompts can reference {{contact.<fieldKey>}} merge tokens.
model NativeCustomField {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String // human-readable label
  fieldKey    String // snake_case identifier used in NativeContact.customFields keys
  dataType    String // "text" | "number" | "date" | "select" | "multiselect" | "boolean" | "phone" | "email" | "url"
  options     Json? // for select/multiselect: string[]
  placeholder String?
  position    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, fieldKey])
  @@index([workspaceId, position])
}

// ─────────────────────────────────────────────────────────────────────────
// TICKETING — email-driven case management for native-CRM workspaces.
//
// Tickets are promoted from widget conversations when an operator wants
// to follow up over email instead of keeping the chat thread open
// (visitor closed the tab, needs longer turnaround, etc). A ticket has
// a status workflow, assignment, priority, an email-based message
// thread, and auto-close/reopen behaviour driven by TicketingSettings.
//
// Feature-gated: scale plan + workspace has TicketingSettings.enabled.
// ─────────────────────────────────────────────────────────────────────────

model Ticket {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation("WorkspaceTickets", fields: [workspaceId], references: [id], onDelete: Cascade)

  // Per-workspace sequential number for display (#1042). Generated at
  // create time via a SELECT MAX(...)+1 inside the same txn — cheap
  // for hundreds-per-day volume; if it ever becomes a hotspot we
  // migrate to a workspace-scoped sequence.
  ticketNumber Int

  // Optional link back to the widget conversation that became this
  // ticket. Null = ticket created from scratch (manual entry, future
  // inbound-email flow).
  conversationId String?             @unique
  conversation   WidgetConversation? @relation("ConversationTicket", fields: [conversationId], references: [id], onDelete: SetNull)

  // Denormalised brand for reporting + filtering. Stamped at promote
  // time from conversation.widget.brandId. Kept in sync via the same
  // path that writes the ticket — we deliberately don't follow the
  // conversation chain at query time because the chain can become
  // SetNull-orphaned and reporting needs to survive that.
  brandId String?
  brand   Brand?  @relation("TicketBrand", fields: [brandId], references: [id], onDelete: SetNull)

  // Required contact details. The promote-from-conversation flow
  // refuses without an email, so we can safely assume it's set.
  contactEmail String
  contactName  String?
  contactPhone String?
  // Native-CRM contact link when the email matched an existing
  // NativeContact during promotion.
  crmContactId String?

  subject  String @db.VarChar(255)
  priority String @default("normal") // 'low' | 'normal' | 'high' | 'urgent'
  status   String @default("open") // 'open' | 'pending' | 'on_hold' | 'resolved' | 'closed'

  // Assignment — same pattern as WidgetConversation. assignedUserId
  // points at User.id; assignedAt powers SLA + reporting.
  assignedUserId String?
  assignedUser   User?     @relation("TicketAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedAt     DateTime?

  // Who created this ticket (manual entry or the operator who promoted
  // a conversation). Nullable — system-created tickets have no creator.
  // SetNull so deleting a user doesn't cascade-delete their tickets.
  createdByUserId String?
  createdByUser   User?   @relation("TicketCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Operator-facing summary of the source chat, stamped at promote time
  // so the agent sees the gist at the top of the ticket without opening
  // the transcript. Null for manually-created tickets (no source chat).
  summary String? @db.Text

  // Activity bookkeeping for auto-close + reopen + sort.
  // - lastActivityAt: any change (message, status, assignment) bumps this.
  // - lastInboundAt:  last reply FROM the customer. Auto-close uses this.
  // - lastOutboundAt: last reply FROM the team.
  // - closedAt/reopenedAt: terminal-state timestamps for reporting.
  lastActivityAt DateTime  @default(now())
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  closedAt       DateTime?
  reopenedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    TicketMessage[]
  replyDrafts TicketReplyDraft[]

  @@unique([workspaceId, ticketNumber])
  @@index([workspaceId, status, lastActivityAt])
  @@index([workspaceId, assignedUserId, status])
  @@index([workspaceId, contactEmail])
  @@index([workspaceId, brandId, status])
}

model TicketMessage {
  id       String @id @default(cuid())
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // 'inbound'       = from the customer (email reply parsed by the
  //                   inbound webhook, or pulled from the source chat
  //                   when the ticket was promoted)
  // 'outbound'      = team reply, sent via Resend
  // 'internal_note' = team-only note, never emailed out
  direction String

  fromEmail String?
  fromName  String?

  // Plain-text body is canonical; bodyHtml is optional for richer
  // outbound emails or when the inbound parser captured HTML too.
  body     String  @db.Text
  bodyHtml String? @db.Text

  // RFC 5322 Message-ID + In-Reply-To, used to thread inbound replies
  // back onto the right ticket. Optional today; populated by the
  // inbound-email webhook when wired up.
  messageId String?
  inReplyTo String?

  // Outbound provenance — who sent it from the dashboard, when Resend
  // confirmed acceptance.
  sentByUserId String?
  sentByUser   User?     @relation("TicketMessageAuthor", fields: [sentByUserId], references: [id], onDelete: SetNull)
  sentAt       DateTime?

  // Delivery-failure bookkeeping. Before these fields a failed Resend send
  // was indistinguishable from a deliberate sendEmail=false (both left
  // sentAt null), so failures were invisible in the thread and nothing ever
  // retried them. emailNextRetryAt non-null = the retry cron owns it;
  // null + emailError = terminal failure (non-transient, or retries
  // exhausted) that the operator has to resolve.
  emailError       String?
  emailAttempts    Int       @default(0)
  emailNextRetryAt DateTime?

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@index([messageId])
  @@index([emailNextRetryAt])
}

// A composed ticket reply held for sign-off before it reaches the customer.
// Submitted from the dashboard compose box ("Submit for approval"); reviewed
// by portal users of the ticket's brand on /portal/approvals. Approving
// sends the email through the same Resend path as a direct reply and stamps
// sentMessageId with the resulting TicketMessage.
model TicketReplyDraft {
  id       String @id @default(cuid())
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  body String @db.Text

  // 'pending' | 'approved' | 'rejected' | 'cancelled'
  status String @default("pending")

  submittedByUserId String?
  submittedByUser   User?   @relation("TicketDraftSubmitter", fields: [submittedByUserId], references: [id], onDelete: SetNull)

  // Reviewer is a PORTAL user (the brand's own people sign off on what
  // goes to their customers). reviewedByEmail survives account deletion
  // and covers super-admin preview sessions that have no PortalUser row.
  reviewedByPortalUserId String?
  reviewedByPortalUser   PortalUser? @relation("TicketDraftReviewer", fields: [reviewedByPortalUserId], references: [id], onDelete: SetNull)
  reviewedByEmail        String?
  reviewedAt             DateTime?
  reviewNote             String?     @db.Text

  // TicketMessage created when the approved draft was emailed out.
  sentMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId, status])
  @@index([status, createdAt])
}

model TicketingSettings {
  workspaceId String    @id
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Master toggle. Plan gate is separate — both must be on for the
  // ticketing UI to render and for the cron to act.
  enabled Boolean @default(false)

  // Auto-close idle tickets after N days without an inbound reply.
  // 0 disables auto-close. Default 7d matches Zendesk/Help Scout.
  autoCloseAfterDays Int @default(7)

  // When a NEW inbound message lands on a closed/resolved ticket,
  // bump it back to 'open' so it isn't lost. Off lets teams hold a
  // "permanently closed" stance for spam follow-ups etc.
  autoReopenOnReply Boolean @default(true)

  // Outbound email identity. fromEmail must be a verified Resend
  // sender on the workspace's domain — we don't validate here, the
  // send call surfaces the Resend error if it isn't.
  fromEmail String?
  fromName  String?

  // Appended to every outbound reply. Operators paste their team's
  // standard sign-off / hours / disclaimer.
  signature String? @db.Text

  updatedAt DateTime @updatedAt
}

/// Workspace-global live-chat / queue settings (mirrors TicketingSettings
/// — one row per workspace). Capacity is a single workspace-total number
/// per Ryan's decision: when this many human chats are live at once, new
/// human requests wait in the queue.
model LiveChatSettings {
  workspaceId String    @id
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Master toggle for the queue. Off = exactly the wave-1 behaviour
  // (no capacity cap, handoffs assign or fall back immediately).
  queueEnabled            Boolean @default(false)
  // Workspace-total ceiling on LIVE human chats (assigned + not ended).
  // AI-only chats don't count. New human requests past this queue.
  maxConcurrentHumanChats Int     @default(5)
  // Show the optional built-in mini-game to waiting visitors.
  queueGameEnabled        Boolean @default(false)
  // Offer waiting visitors a "leave your email" action that opens a
  // support ticket (requires ticketing to be active).
  queueEmailTicketEnabled Boolean @default(false)
  // Operator-authored copy shown in the visitor's queue banner.
  queueMessage            String? @db.Text

  // Time-based escalation. When a conversation assigned to a human has a
  // waiting visitor (their message is the last one) and the operator hasn't
  // replied for this many minutes, the stale-conversations cron escalates.
  // 0 = disabled (default). escalateReassign=false pings the operator only;
  // true also returns the chat to the queue so another operator picks it up.
  escalateAfterMinutes Int     @default(0)
  escalateReassign     Boolean @default(false)

  // Auto-away: flip members to Away after this many minutes without any
  // dashboard activity, so routing never sends chats to someone who went
  // home with the pill still green. Members the heartbeat has never seen
  // (lastActivityAt null) are exempt. A heartbeat from a system-flipped
  // member restores them automatically; manual Away is never overridden.
  autoAwayEnabled Boolean @default(true)
  autoAwayMinutes Int     @default(15)

  updatedAt DateTime @updatedAt
}

// ─── External metrics API ────────────────────────────────────────────────────
// API keys, SLA policy targets, and request audit log for the /api/v1/...
// read-only metrics API used by external reporting tools.

model ApiKey {
  id              String    @id @default(cuid())
  workspaceId     String? // null = org-scope key
  scope           String // 'workspace' | 'org'
  name            String
  prefix          String // first 12 chars of the raw key, shown in UI
  hashedKey       String    @unique // SHA-256 hex of the raw key
  lastUsedAt      DateTime?
  createdByUserId String?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, revokedAt])
}

model SlaPolicy {
  id                String   @id @default(cuid())
  workspaceId       String
  priority          String // 'urgent' | 'high' | 'normal' | 'low' | 'default'
  firstResponseMins Int? // target minutes; null = not tracked
  resolutionMins    Int?
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, priority])
  @@index([workspaceId])
}

model ApiRequestLog {
  id          String   @id @default(cuid())
  apiKeyId    String?
  scope       String
  workspaceId String?
  path        String
  status      Int
  durationMs  Int
  createdAt   DateTime @default(now())

  @@index([apiKeyId, createdAt])
  @@index([createdAt])
}

// ─── Shared-login kiosk operators ───────────────────────────────────
//
// Lets a team run multiple live-chat operators off ONE shared terminal
// without each person needing their own email/OAuth login. The mechanism
// is deliberately thin: each operator identity is still a REAL User +
// WorkspaceMember (role 'agent') — so presence, round-robin routing, and
// message attribution all work unchanged, keyed on the real User.id. The
// kiosk layer only adds (a) a shared per-workspace PIN that unlocks the
// operator picker, and (b) a per-operator PIN that mints a normal NextAuth
// session as that operator. No parallel "operator" entity, no re-keyed
// routing — a kiosk operator IS a workspace member.

/// One shared PIN per workspace. Entering it on /kiosk/<slug> unlocks the
/// operator name-grid (but grants no app access on its own). PIN is bcrypt
/// hashed — plaintext is shown once at creation and never stored.
model KioskCredential {
  id             String    @id @default(cuid())
  workspaceId    String    @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  secretHash     String
  // Last 4 of the PIN, for a masked "•••• 1234" display in settings.
  lastFour       String?
  createdBy      String
  // Soft kill-switch — disable the shared door without dropping operators.
  disabledAt     DateTime?
  // Brute-force guard for the low-entropy PIN.
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  rotatedAt      DateTime?
  createdAt      DateTime  @default(now())
}

/// A kiosk-selectable operator identity. Backed by a synthetic User
/// (non-deliverable email, no OAuth account) + a WorkspaceMember(role
/// 'agent'). The secondary PIN gates "become this operator" after the
/// shared door is open.
model KioskOperator {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // The real User this identity maps to. One operator per user.
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinHash        String
  displayName    String
  disabledAt     DateTime?
  createdBy      String
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())

  @@index([workspaceId])
}

// ─── Real-time Co-Pilot ─────────────────────────────────────────────
//
// Foundation models for the screen-share co-pilot (spec at
// /Users/ryan/Downloads/vox-ai-realtime-copilot-spec.md). Translated
// from the spec's brand_id-tenanted shape to workspaceId tenancy +
// application-layer scoping. v0 is read-only (toolCall.isWrite flag
// remains false for now); write-path lands in P2 without schema work.
// All foreign keys app-enforced via workspaceId equality checks in
// the route handlers — no RLS, matches the rest of the repo.

model CopilotSession {
  id              String    @id @default(cuid())
  workspaceId     String
  startedByUserId String?
  /// 'in_app_webrtc' (v0) | 'recall_meeting_bot' (P2 seam)
  channel         String    @default("in_app_webrtc")
  /// 'active' | 'ended' | 'error'
  status          String    @default("active")
  /// 'gemini-live' | 'gpt-realtime' — populated when the RealtimeModelProvider resolves
  model           String?
  roomId          String?
  locale          String    @default("en-AU")
  workflowKey     String?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationSecs    Int?
  endedReason     String?
  // Cost telemetry — written incrementally by the runtime so unit
  // cost per session is queryable from day one (spec §8).
  audioInSecs     Decimal   @default(0) @db.Decimal(10, 2)
  audioOutSecs    Decimal   @default(0) @db.Decimal(10, 2)
  videoFrames     Int       @default(0)
  toolCallCount   Int       @default(0)
  metadata        Json      @default("{}")

  workspace Workspace               @relation("WorkspaceCopilotSessions", fields: [workspaceId], references: [id], onDelete: Cascade)
  turns     CopilotTranscriptTurn[]
  events    CopilotScreenEvent[]
  toolCalls CopilotToolCall[]
  evals     CopilotEvalRecord[]

  @@index([workspaceId, startedAt(sort: Desc)])
}

model CopilotTranscriptTurn {
  id          String   @id @default(cuid())
  sessionId   String
  workspaceId String
  /// 'user' | 'agent' | 'system' | 'tool'
  role        String
  text        String?  @db.Text
  tokens      Int?
  ts          DateTime @default(now())

  session CopilotSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  evals   CopilotEvalRecord[]

  @@index([sessionId, ts])
}

model CopilotScreenEvent {
  id              String   @id @default(cuid())
  sessionId       String
  workspaceId     String
  visionSummary   String?  @db.Text
  detectedContext Json     @default("{}")
  /// NULL by default — raw-frame retention is off unless explicitly enabled (spec §11)
  frameRef        String?
  ts              DateTime @default(now())

  session CopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, ts])
}

model CopilotToolCall {
  id            String   @id @default(cuid())
  sessionId     String
  workspaceId   String
  toolName      String
  args          Json     @default("{}")
  resultSummary String?  @db.Text
  /// v0 reads only; P2 write-path flips this true and requires confirmedBy
  isWrite       Boolean  @default(false)
  confirmedBy   String?
  latencyMs     Int?
  ts            DateTime @default(now())

  session CopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, ts])
}

model CopilotEvalRecord {
  id                    String   @id @default(cuid())
  sessionId             String
  workspaceId           String
  turnId                String?
  /// 'turn' | 'session'
  scope                 String
  /// 'helpful' | 'neutral' | 'harmful' — mirrors RetrievalEvalResult rubric
  groundingFaithfulness String?
  taskSuccess           Boolean?
  notes                 String?  @db.Text
  ts                    DateTime @default(now())

  session CopilotSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  turn    CopilotTranscriptTurn? @relation(fields: [turnId], references: [id], onDelete: SetNull)

  @@index([sessionId])
}

// ─── Cron heartbeats ────────────────────────────────────────────────
// One row per cron job, upserted on every run (lib/cron-heartbeat).
// The /api/admin/cron-health endpoint reads these to answer "which
// background jobs are stale or failing" — token refresh, outbox
// drains, ingestion. Without it a dead cron was invisible until
// customers noticed the symptoms.
model CronHeartbeat {
  name                String    @id
  lastRunAt           DateTime
  lastSuccessAt       DateTime?
  lastError           String?   @db.Text
  consecutiveFailures Int       @default(0)
}

// Workspace-authored SOPs the Co-Pilot can run in 'sop' mode: a named
// series of steps walked with the user inside a timebox (e.g. a
// 20-minute client-onboarding procedure). Steps are a JSON string
// array — progress tracking is conversational (the model checks steps
// off with the user), unlike the machine-predicated built-in
// onboarding workflow.
model CopilotSop {
  id             String    @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation("WorkspaceCopilotSops", fields: [workspaceId], references: [id], onDelete: Cascade)
  title          String
  goal           String    @db.Text
  timeboxMinutes Int       @default(20)
  steps          Json      @default("[]")
  createdAt      DateTime  @default(now())

  @@index([workspaceId])
}

// First-class Co-Pilot agents: named personas a workspace creates.
// Each has its own knowledge scope, an optional procedure (steps; empty
// = general support), and a PLAYBOOK distilled from uploaded recordings
// of human calls — phrasings, objection handling, screen navigation
// anchors. No neural training: behavior = persona + steps + playbook +
// retrieved knowledge, all inspectable text.
model CopilotAgent {
  id                 String             @id @default(cuid())
  workspaceId        String
  workspace          Workspace          @relation("WorkspaceCopilotAgents", fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  /// 'support' | 'onboarding' | 'other' — chosen at creation
  type               String             @default("support")
  persona            String?            @db.Text
  /// How to open the call (the agent's first line / greeting intent)
  openingLine        String?            @db.Text
  /// What information to ask the user for during the session
  collectInfo        String?            @db.Text
  knowledgeDomainIds String[]           @default([])
  steps              Json               @default("[]")
  /// "simple" = the flat `steps` checklist (default). "advanced" = the
  /// `blocks` flow below — conversational building blocks that can branch.
  procedureMode      String             @default("simple")
  /// Advanced-mode conversational building blocks. Array of:
  /// { id, label, instruction, waitForResponse, rules: [{ id, when,
  ///   then: { action: "jump"|"instruct"|"end", targetId?, instruction? } }] }.
  /// Each block is a conversational move; rules branch on what the live
  /// agent observes. Empty/unused when procedureMode = "simple".
  blocks             Json               @default("[]")
  timeboxMinutes     Int                @default(30)
  playbook           String?            @db.Text
  /// Structured screen/element inventory distilled across ALL of this
  /// agent's recordings (page → notable controls → what each does → how
  /// to reach it). Lets a live session reason about a screen it saw in
  /// one recording while the user is on a related screen now — the
  /// bridge from recordings to educated UI guesses. Markdown prose,
  /// operator-inspectable; distilled alongside `playbook`.
  uiMap              String?            @db.Text
  /// Voice selection. A Gemini prebuilt voice name (pinned, kills accent
  /// drift), or 'rotate' = a different voice + human intro name each
  /// session (team-of-humans). Null = Gemini's default voice. See
  /// lib/copilot/voices.ts.
  voice              String?
  /// The one application/product this agent operates inside (e.g. "the
  /// Acme CRM dashboard"). Boxes the agent to that app so it grounds in
  /// the real UI instead of guessing across arbitrary screens.
  appContext         String?            @db.Text
  /// Public key for embed/link launches (mirror ChatWidget.publicKey).
  /// Null until the agent is published.
  publicKey          String?            @unique
  published          Boolean            @default(false)
  /// Origins allowed to embed the launch (empty = any; same posture as
  /// the dashboard CSP — agencies resell on countless domains).
  allowedDomains     String[]           @default([])
  createdAt          DateTime           @default(now())
  recordings         CopilotRecording[]

  @@index([workspaceId])
}

// Uploaded recordings of human calls (audio or screen video). Processed
// in the background: Gemini transcribes the dialogue AND extracts a
// timestamped screen walkthrough from the video track, then the
// distiller folds every processed recording into the agent's playbook.
model CopilotRecording {
  id               String       @id @default(cuid())
  agentId          String
  agent            CopilotAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  workspaceId      String
  storageKey       String
  originalFilename String
  status           String       @default("queued") // queued | processing | done | failed
  transcript       String?      @db.Text
  walkthrough      String?      @db.Text
  error            String?
  createdAt        DateTime     @default(now())

  @@index([agentId])
}

/// Homepage / marketing-site email capture (launch updates, newsletter).
/// Deliberately standalone — NOT tied to a Workspace or NativeContact, so
/// the public marketing site never couples to a tenant. Written only by
/// the unauthenticated POST /api/public/marketing-lead route.
model MarketingLead {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("homepage")
  utm       Json?
  referrer  String?
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─── Conversation Q&A Mining ────────────────────────────────────────────────
// Cold-start helper: a subaccount with a live CRM (LeadConnector) already
// has months of real conversations where humans answered customer questions.
// A ConversationMiningRun reads that history in the background, an LLM
// extracts question→answer pairs from the human-answered exchanges, and the
// drafts land in MinedQaPair (staging) for operator approval before any
// become live KnowledgeEntry rows.
//
// FK columns are plain scalars (no Prisma relation fields) — these are
// append-only job/staging tables and the parent models (Workspace/Agent/
// KnowledgeCollection) stay untouched. The hand-run DDL adds the FK
// constraints with ON DELETE CASCADE; see prisma/MIGRATIONS.md.
model ConversationMiningRun {
  id                   String   @id @default(cuid())
  workspaceId          String
  // The agent whose live CRM connection is being mined, and the collection
  // the approved pairs will be written into.
  agentId              String
  collectionId         String
  // queued → running → complete | failed. Claimed compare-and-swap by the
  // mine-conversations cron, same pattern as IngestionRun.
  status               String   @default("queued")
  // Inclusive lower / exclusive upper bound of the mining window. Defaults
  // applied at create time (last 12 months) but operator-editable.
  windowStart          DateTime
  windowEnd            DateTime
  // Hard ceiling on conversations scanned this run — bounds cost even if the
  // window is wide. Continuation runs respect the remaining budget.
  maxConversations     Int      @default(2000)
  // Logical LLM key used for extraction (resolved via lib/llm registry).
  model                String   @default("auto")
  // Deadline-bounded continuation cursor: epoch-ms of the last conversation's
  // lastMessageDate processed. Next tick resumes from startAfterDate=cursor.
  cursor               String?
  conversationsScanned Int      @default(0)
  pairsGenerated       Int      @default(0)
  estimatedTokens      Int      @default(0)
  actualTokens         Int      @default(0)
  error                String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([status, createdAt])
  @@index([workspaceId])
  @@index([collectionId])
}

// A single draft Q&A pair extracted from a mined conversation. Lives in
// staging until an operator approves it (→ a KnowledgeEntry with source='qa'
// in the target collection) or rejects it.
model MinedQaPair {
  id                   String   @id @default(cuid())
  runId                String
  workspaceId          String
  collectionId         String
  question             String   @db.Text
  answer               String   @db.Text
  // Provenance so a reviewer can audit the source thread.
  sourceConversationId String?
  sourceSnippet        String?  @db.Text
  // Model's self-reported 0..1 confidence the pair is a genuine,
  // reusable human answer (not chit-chat / one-off).
  confidence           Float    @default(0)
  // pending → approved | rejected. Approval creates the KnowledgeEntry.
  status               String   @default("pending")
  // Set once approved so the staging row links to its live entry.
  knowledgeEntryId     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([collectionId, status])
  @@index([runId])
  @@index([workspaceId])
}

// ─── Google content connector (Drive now, Gmail later) ──────────────────────
// Workspace-scoped OAuth connection used to import Drive files (and, once the
// restricted gmail.readonly scope passes Google verification, Gmail threads)
// into knowledge collections. Reuses the app's existing Google OAuth client;
// this is a SEPARATE consent round-trip from NextAuth login that adds the
// drive.file scope and stores its own refresh token.
//
// Drive uses the non-restricted `drive.file` scope + the Google Picker, so the
// app only ever sees files the operator explicitly picked — no whole-drive
// access, no restricted-scope verification needed. The whole feature is gated
// behind the GOOGLE_CONTENT_ENABLED env flag until the Drive API + Picker key
// are provisioned on the existing Google Cloud project.
//
// Scalar workspaceId (FK + cascade in hand-run DDL), matching the mining tables.
model GoogleContentConnection {
  id           String   @id @default(cuid())
  workspaceId  String   @unique
  // The connected Google account's email, for display ("Connected as …").
  email        String?
  // OAuth refresh token used to mint short-lived access tokens for Drive/
  // Picker calls. Server-only.
  refreshToken String   @db.Text
  // Space-separated granted scopes, so the UI can tell whether Gmail is
  // available on this connection once that scope ships.
  scopes       String   @default("")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Agency-level CRM connection (per-location widget control) ─────────────
// Deliberately separate from the Location token store: this is a DIFFERENT
// LeadConnector marketplace app (agency-scoped install, its own client
// id/secret). Hierarchy: ONE WIDGET connects to ONE AGENCY — the connection
// hangs off the ChatWidget, and its locations toggle that widget on/off per
// sub-account. workspaceId is denormalized from the widget for scoping
// queries (portal access, admin lists).

model AgencyConnection {
  id                   String           @id @default(cuid())
  widgetId             String           @unique
  widget               ChatWidget       @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  workspaceId          String
  workspace            Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider             String           @default("leadconnector")
  companyId            String
  // Agency display name, fetched from GET /companies/:id at connect time
  // and refreshed on sync. Nullable — pre-migration rows and 403s (scope
  // missing) fall back to showing the raw companyId.
  companyName          String?
  accessToken          String
  refreshToken         String
  expiresAt            DateTime
  scope                String
  tokenRefreshFailedAt DateTime?
  connectedByUserId    String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  locations            AgencyLocation[]

  @@index([workspaceId])
}

model AgencyLocation {
  id                     String           @id @default(cuid())
  connectionId           String
  connection             AgencyConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  locationId             String
  name                   String
  city                   String?
  state                  String?
  country                String?
  email                  String?
  phone                  String?
  widgetEnabled          Boolean          @default(true)
  widgetEnabledUpdatedAt DateTime?
  // Attribution: "user:<userId>" (dashboard) or "portal:<portalUserId>".
  widgetEnabledUpdatedBy String?
  lastSyncedAt           DateTime         @default(now())
  // Set when the location vanished from the agency on a sync; cleared if it
  // reappears. Soft flag so a toggle survives remove/re-add. Never deleted.
  removedAt              DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@unique([connectionId, locationId])
  @@index([locationId])
}

// ─── Portal AI insights cache ───────────────────────────────────────────────
// One cached synthesis per portal (aiSummary pattern: compute on demand,
// cache, refresh when stale — no cron). content is the model's JSON:
// [{ headline, detail, suggestedAction }].
model PortalInsight {
  id          String   @id @default(cuid())
  portalId    String   @unique
  portal      Portal   @relation(fields: [portalId], references: [id], onDelete: Cascade)
  content     Json
  windowDays  Int      @default(7)
  generatedAt DateTime @default(now())
}

// ── Voice-demo prospecting funnel ────────────────────────────────────
// One row per cold-emailed business. Registered cheaply by the outbound
// prospecting tool via /api/v1/demo-prospects; the heavy assets (agent,
// voice config, knowledge domain + crawl) are provisioned lazily on the
// first /try/[slug] visit and live in the internal demos workspace
// (DEMO_WORKSPACE_ID). Claiming re-parents those assets into the
// prospect's real workspace.
// agentId/knowledgeDomainId/ingestionRunId/claimedByUserId/claimedWorkspaceId
// are deliberately loose references (no @relation): the assets live in
// another workspace's bounded context and get re-parented on claim; a
// dangling id after an out-of-band delete must never block or cascade
// into demo rows.
model DemoProspect {
  id                 String    @id @default(cuid())
  slug               String    @unique
  businessName       String
  websiteUrl         String
  websiteDomain      String // normalized host, e.g. "acmeplumbing.com" — hand-run partial UNIQUE index enforces one live (non expired/claimed/failed) demo per domain; Prisma can't express a partial unique index in this schema, see prisma/migrations/manual_demo_prospects.sql
  contactEmail       String?
  vertical           String? // maps to a landing page + template preset
  templates          Json? // optional per-prospect {prompt,instructions,firstMessage} template overrides
  metadata           Json? // free-form from the prospecting tool; string values become template vars
  status             String    @default("registered") // registered | provisioning | ready | failed | expired | claimed
  agentId            String?
  knowledgeDomainId  String?
  ingestionRunId     String?
  clickedAt          DateTime?
  firstCallAt        DateTime?
  callCount          Int       @default(0)
  totalCallSecs      Int       @default(0)
  claimedByUserId    String?
  claimedWorkspaceId String?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([websiteDomain])
  @@index([status, expiresAt])
}

// One row per public demo call. Powers the abuse guards on the /try
// token route (per-IP cooldown + global concurrency) without a session
// table: a call counts as "active" while startedAt is within the demo
// cap and endedAt is null, so stale rows age out of the guard queries
// by time alone — no reaper needed at the call level.
model DemoTryCall {
  id         String    @id @default(cuid())
  prospectId String // soft reference (no @relation): prospect rows are never hard-deleted — the reaper flips status instead
  ip         String
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  secs       Int       @default(0)

  @@index([ip, startedAt])
  @@index([startedAt, endedAt])
  @@index([prospectId])
}
