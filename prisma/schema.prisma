generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ──────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  locations     UserLocation[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model UserLocation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  role       String   @default("owner")
  createdAt  DateTime @default(now())
  @@unique([userId, locationId])
}

enum ConversationState {
  ACTIVE
  PAUSED
  COMPLETED
}

enum StopConditionType {
  APPOINTMENT_BOOKED
  KEYWORD
  MESSAGE_COUNT
  OPPORTUNITY_STAGE
}

enum FollowUpStatus {
  SCHEDULED
  SENT
  CANCELLED
  FAILED
}

enum ResponseLength {
  BRIEF
  MODERATE
  DETAILED
}

enum FormalityLevel {
  CASUAL
  NEUTRAL
  FORMAL
}

model Location {
  id             String   @id
  companyId      String
  userId         String
  userType       String
  scope          String
  accessToken    String
  refreshToken   String
  refreshTokenId String
  expiresAt      DateTime
  installedAt             DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  onboardingCompletedAt   DateTime?

  agents      Agent[]
  messageLogs MessageLog[]
  users       UserLocation[]

  @@index([companyId])
}

model Agent {
  id           String   @id @default(cuid())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name         String
  systemPrompt String   @db.Text
  instructions String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enabledTools     String[] @default(["get_contact_details", "send_sms", "update_contact_tags", "get_opportunities", "move_opportunity_stage", "add_contact_note"])
  calendarId       String?

  qualifyingStyle     String   @default("strict")    // "strict" | "natural"
  fallbackBehavior    String   @default("message")  // "message" | "transfer" | "message_and_transfer"
  fallbackMessage     String?  @db.Text

  agentPersonaName    String?
  responseLength      ResponseLength   @default(MODERATE)
  formalityLevel      FormalityLevel   @default(NEUTRAL)
  useEmojis           Boolean          @default(false)
  neverSayList        String[]         @default([])
  simulateTypos       Boolean          @default(false)
  typingDelayEnabled  Boolean          @default(false)
  typingDelayMinMs    Int              @default(500)
  typingDelayMaxMs    Int              @default(3000)
  languages           String[]         @default(["en"])

  knowledgeEntries KnowledgeEntry[]
  routingRules     RoutingRule[]
  messageLogs      MessageLog[]
  stopConditions      StopCondition[]
  followUpSequences   FollowUpSequence[]
  qualifyingQuestions QualifyingQuestion[]
  conversationStates  ConversationStateRecord[]
  contactMemories     ContactMemory[]
  conversationMessages ConversationMessage[]
  vapiConfig          VapiConfig?

  @@index([locationId, isActive])
}

model KnowledgeEntry {
  id            String   @id @default(cuid())
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title         String
  content       String   @db.Text
  source        String   @default("manual")
  sourceUrl     String?
  tokenEstimate Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([agentId])
}

model RoutingRule {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  priority  Int      @default(10)
  ruleType  RuleType
  value     String?
  createdAt DateTime @default(now())

  @@index([agentId, priority])
}

enum RuleType {
  ALL
  TAG
  PIPELINE_STAGE
  KEYWORD
}

model MessageLog {
  id               String    @id @default(cuid())
  locationId       String
  location         Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  agentId          String?
  agent            Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  contactId        String
  conversationId   String
  inboundMessage   String    @db.Text
  outboundReply    String?   @db.Text
  actionsPerformed String[]
  tokensUsed       Int       @default(0)
  toolCallTrace    Json?
  status           LogStatus @default(PENDING)
  errorMessage     String?   @db.Text
  createdAt        DateTime  @default(now())

  @@index([locationId, createdAt(sort: Desc)])
  @@index([agentId, createdAt(sort: Desc)])
}

enum LogStatus {
  PENDING
  SUCCESS
  ERROR
  SKIPPED
}

model StopCondition {
  id            String            @id @default(cuid())
  agentId       String
  agent         Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conditionType StopConditionType
  value         String?
  pauseAgent    Boolean           @default(true)
  createdAt     DateTime          @default(now())
  @@index([agentId])
}

model FollowUpSequence {
  id            String         @id @default(cuid())
  agentId       String
  agent         Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name          String
  isActive      Boolean        @default(true)
  triggerType   String         @default("always")   // "always" | "no_reply" | "keyword" | "agent"
  triggerValue  String?                               // hours for no_reply, comma-sep keywords for keyword, null for agent/always
  steps         FollowUpStep[]
  jobs          FollowUpJob[]
  createdAt     DateTime       @default(now())
  @@index([agentId])
}

model FollowUpStep {
  id         String           @id @default(cuid())
  sequenceId String
  sequence   FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber Int
  delayHours Int
  message    String           @db.Text
  @@index([sequenceId, stepNumber])
}

model FollowUpJob {
  id             String           @id @default(cuid())
  sequenceId     String
  sequence       FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  locationId     String
  contactId      String
  conversationId String?
  currentStep    Int              @default(1)
  status         FollowUpStatus   @default(SCHEDULED)
  scheduledAt    DateTime
  lastSentAt     DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime         @default(now())
  @@index([status, scheduledAt])
  @@index([locationId, contactId])
}

model QualifyingQuestion {
  id           String   @id @default(cuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  question     String   @db.Text
  fieldKey     String
  required     Boolean  @default(true)
  order        Int      @default(0)
  answerType   String   @default("text")
  choices      String[] @default([])
  conditionOp  String?
  conditionVal String?
  actionType   String?
  actionValue  String?
  ghlFieldKey  String?
  overwrite    Boolean  @default(false)
  createdAt    DateTime @default(now())
  @@index([agentId, order])
}

model ConversationStateRecord {
  id                String            @id @default(cuid())
  agentId           String
  agent             Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  locationId        String
  contactId         String
  conversationId    String?
  state             ConversationState @default(ACTIVE)
  messageCount      Int               @default(0)
  pauseReason       String?
  pausedAt          DateTime?
  resumedAt         DateTime?
  qualifyingAnswers Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  @@unique([agentId, contactId])
  @@index([locationId, state])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  locationId     String
  contactId      String
  conversationId String
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now())
  @@index([agentId, contactId, createdAt(sort: Asc)])
  @@index([conversationId, createdAt(sort: Asc)])
}

model ContactMemory {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  locationId String
  contactId  String
  summary    String   @db.Text
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  @@unique([agentId, contactId])
}

model VapiConfig {
  id              String   @id @default(cuid())
  agentId         String   @unique
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  phoneNumberId   String?
  phoneNumber     String?
  voiceProvider   String   @default("elevenlabs")
  voiceId         String   @default("EXAVITQu4vr4xnSDxMaL")
  voiceName       String?
  stability       Float    @default(0.5)
  similarityBoost Float    @default(0.75)
  speed           Float    @default(1.0)
  style           Float    @default(0.0)
  firstMessage    String?  @db.Text
  endCallMessage  String?  @db.Text
  maxDurationSecs Int      @default(600)
  recordCalls     Boolean  @default(true)
  backgroundSound String?
  endCallPhrases  String[] @default([])
  language        String?
  voiceTools      Json?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CallLog {
  id           String   @id @default(cuid())
  locationId   String
  agentId      String?
  contactId    String?
  contactPhone String?
  vapiCallId   String?  @unique
  direction    String   @default("inbound")
  status       String   @default("completed")
  durationSecs Int?
  transcript   String?  @db.Text
  summary      String?  @db.Text
  recordingUrl String?
  tokensUsed   Int      @default(0)
  endedReason  String?
  createdAt    DateTime @default(now())
  @@index([locationId, createdAt(sort: Desc)])
  @@index([agentId, createdAt(sort: Desc)])
}

model ScheduledMessage {
  id           String   @id @default(cuid())
  locationId   String
  agentId      String?
  contactId    String
  channel      String   @default("SMS")
  message      String   @db.Text
  scheduledAt  DateTime
  sentAt       DateTime?
  status       String   @default("pending")  // pending, sent, cancelled, failed
  createdAt    DateTime @default(now())
  @@index([status, scheduledAt])
  @@index([locationId, contactId])
}

model LeadScore {
  id         String   @id @default(cuid())
  locationId String
  agentId    String
  contactId  String
  score      Int
  reason     String
  createdAt  DateTime @default(now())
  @@unique([agentId, contactId])
  @@index([locationId, score(sort: Desc)])
}

model MessageBuffer {
  id             String   @id @default(cuid())
  locationId     String
  contactId      String
  conversationId String
  body           String   @db.Text
  processed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  @@index([locationId, contactId, processed, createdAt(sort: Asc)])
}

model Integration {
  id          String   @id @default(cuid())
  locationId  String
  type        String
  name        String
  credentials Json
  config      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([locationId, type])
}
