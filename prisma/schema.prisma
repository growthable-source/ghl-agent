  visitorId        String
  visitor          WidgetVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  agentId          String?
  status           String   @default("active")
  lastMessageAt    DateTime @default(now())
  // Cron debounce for conversation.stale — set when we've already paged
  // about this thread so we don't notify again until the visitor replies.
  staleNotifiedAt  DateTime?
  createdAt        DateTime @default(now())
  messages         WidgetMessage[]
