generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ──────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String?   @unique
  emailVerified         DateTime?
  image                 String?
  theme                 String    @default("midnight")
  companyName           String?
  companySize           String?
  role                  String?
  onboardingCompletedAt DateTime?
  accounts              Account[]
  sessions              Session[]
  locations             UserLocation[]
  workspaces            WorkspaceMember[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model UserLocation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  role       String   @default("owner")
  createdAt  DateTime @default(now())
  @@unique([userId, locationId])
}

// ─── Workspace Architecture ──────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String   @default("🚀")      // emoji avatar
  domain      String?                       // e.g. "acmecorp.com" — for same-domain invite gating

  // ─── Plan & Limits ───
  plan                    String   @default("trial")  // "trial" | "starter" | "growth" | "scale"
  planSelectedDuringTrial String?                      // "starter" | "growth" | "scale"
  billingPeriod           String   @default("monthly") // "monthly" | "annual"
  agentLimit              Int      @default(3)
  messageLimit            Int      @default(1500)      // AI messages per billing period
  messageUsage            Int      @default(0)         // current period usage
  voiceMinuteLimit        Int      @default(0)         // voice minutes per billing period (seconds stored)
  voiceMinuteUsage        Int      @default(0)         // current period voice usage in seconds
  extraAgentCount         Int      @default(0)         // agents beyond plan inclusion
  trialEndsAt             DateTime?                    // set to now+7d on signup

  // ─── Stripe Billing ───
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // ─── Emergency Pause ───
  isPaused   Boolean   @default(false)
  pausedAt   DateTime?
  pausedBy   String?                       // userId who paused the workspace

  members      WorkspaceMember[]
  invites      WorkspaceInvite[]
  locations    Location[]         @relation("WorkspaceLocations")
  agents       Agent[]            @relation("WorkspaceAgents")
  usageRecords UsageRecord[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UsageRecord {
  id                 String    @id @default(cuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type               String                         // "message" | "voice_minute"
  quantity           Int                             // 1 for messages, seconds for voice
  agentId            String?                         // which agent generated the usage
  billingPeriod      String                          // e.g. "2026-04"
  stripeUsageRecordId String?                        // after reporting to Stripe
  createdAt          DateTime  @default(now())

  @@index([workspaceId, billingPeriod])
  @@index([workspaceId, type, createdAt])
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        String    @default("owner")   // "owner" | "admin" | "member"
  createdAt   DateTime  @default(now())
  @@unique([userId, workspaceId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        String    @default("member")  // "admin" | "member"
  invitedBy   String                        // userId of inviter
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  @@unique([workspaceId, email])
  @@index([email])
}

enum ConversationState {
  ACTIVE
  PAUSED
  COMPLETED
}

enum StopConditionType {
  APPOINTMENT_BOOKED
  KEYWORD
  MESSAGE_COUNT
  OPPORTUNITY_STAGE
}

enum FollowUpStatus {
  SCHEDULED
  SENT
  CANCELLED
  FAILED
}

enum ResponseLength {
  BRIEF
  MODERATE
  DETAILED
}

enum FormalityLevel {
  CASUAL
  NEUTRAL
  FORMAL
}

model Location {
  id             String   @id
  workspaceId    String?
  workspace      Workspace? @relation("WorkspaceLocations", fields: [workspaceId], references: [id], onDelete: Cascade)
  companyId      String
  userId         String
  userType       String
  scope          String
  accessToken    String
  refreshToken   String
  refreshTokenId String
  expiresAt      DateTime
  crmProvider    String   @default("ghl")
  installedAt             DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  onboardingCompletedAt   DateTime?

  agents      Agent[]
  messageLogs MessageLog[]
  users       UserLocation[]

  @@index([companyId])
  @@index([workspaceId])
}

model Agent {
  id           String   @id @default(cuid())
  workspaceId  String?
  workspace    Workspace? @relation("WorkspaceAgents", fields: [workspaceId], references: [id], onDelete: Cascade)
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name         String
  systemPrompt String   @db.Text
  instructions String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enabledTools     String[] @default(["get_contact_details", "send_reply", "send_sms", "send_email", "update_contact_tags", "remove_contact_tags", "get_opportunities", "move_opportunity_stage", "add_contact_note", "get_available_slots", "book_appointment", "cancel_appointment", "reschedule_appointment", "create_appointment_note", "get_calendar_events", "find_contact_by_email_or_phone", "upsert_contact", "create_task", "add_to_workflow", "remove_from_workflow", "cancel_scheduled_message", "list_contact_conversations", "mark_opportunity_won", "mark_opportunity_lost", "upsert_opportunity", "list_pipelines"])
  calendarId       String?

  // ─── Workflow picker ───
  // When add_to_workflow / remove_from_workflow tools are enabled, the user
  // pins which published workflows the agent is allowed to act on. Stored
  // with denormalized names so the agent's tool schema can show them without
  // hitting GHL on every invocation. Empty/null = tool is effectively disabled
  // (we drop it from the published tool list at runtime).
  addToWorkflowsPick       Json?   // Array<{ id: string; name: string }>
  removeFromWorkflowsPick  Json?   // Array<{ id: string; name: string }>

  qualifyingStyle     String   @default("strict")    // "strict" | "natural"
  fallbackBehavior    String   @default("message")  // "message" | "transfer" | "message_and_transfer"
  fallbackMessage     String?  @db.Text

  agentPersonaName    String?
  responseLength      ResponseLength   @default(MODERATE)
  formalityLevel      FormalityLevel   @default(NEUTRAL)
  useEmojis           Boolean          @default(false)
  neverSayList        String[]         @default([])
  simulateTypos       Boolean          @default(false)
  typingDelayEnabled  Boolean          @default(false)
  typingDelayMinMs    Int              @default(500)
  typingDelayMaxMs    Int              @default(3000)
  languages           String[]         @default(["en"])

  // ─── Working Hours & Quiet Periods ───
  workingHoursEnabled Boolean          @default(false)
  workingHoursStart   Int              @default(0)    // hour 0-23 (contact-local)
  workingHoursEnd     Int              @default(24)   // hour 0-24
  workingDays         String[]         @default(["mon","tue","wed","thu","fri","sat","sun"])
  timezone            String?                         // IANA, e.g. "America/New_York"

  // ─── Emergency Pause ───
  isPaused            Boolean          @default(false)
  pausedAt            DateTime?

  // ─── Approval Queue ───
  requireApproval     Boolean          @default(false)
  approvalRules       Json?                           // { lowSentiment: true, firstContact: true, ... }

  knowledgeEntries KnowledgeEntry[]
  routingRules     RoutingRule[]
  detectionRules   AgentRule[]
  listeningRules   AgentListeningRule[]
  messageLogs      MessageLog[]
  stopConditions      StopCondition[]
  followUpSequences   FollowUpSequence[]
  qualifyingQuestions QualifyingQuestion[]
  conversationStates  ConversationStateRecord[]
  contactMemories     ContactMemory[]
  conversationMessages ConversationMessage[]
  vapiConfig          VapiConfig?
  channelDeployments  ChannelDeployment[]
  triggers            AgentTrigger[]

  @@index([locationId, isActive])
  @@index([workspaceId])
}

model KnowledgeEntry {
  id            String   @id @default(cuid())
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title         String
  content       String   @db.Text
  source        String   @default("manual")
  sourceUrl     String?
  tokenEstimate Int      @default(0)
  status        String   @default("ready")    // "pending" | "indexing" | "ready" | "failed"
  contentHash   String?                        // for crawl dedupe / change detection
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([agentId])
  @@index([agentId, status])
}

// ─── Recurring crawl schedule ──────────────────────────────────────────────
model CrawlSchedule {
  id          String   @id @default(cuid())
  agentId     String
  url         String
  frequency   String                              // "daily" | "weekly" | "monthly"
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime
  lastStatus  String?                             // "success" | "failed" | "no_changes"
  lastError   String?  @db.Text
  newChunks   Int      @default(0)                // total new chunks across all runs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([agentId])
  @@index([isActive, nextRunAt])
}

model RoutingRule {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  priority  Int      @default(10)
  ruleType  RuleType
  value     String?
  createdAt DateTime @default(now())

  @@index([agentId, priority])
}

enum RuleType {
  ALL
  TAG
  PIPELINE_STAGE
  KEYWORD
}

// ─── Detection Rules ──────────────────────────────────────────────────────
// User-authored "IF the contact says X, THEN update field Y to value Z" rules.
// The condition is a natural-language description plus few-shot examples —
// the agent evaluates it semantically against each inbound message and uses
// the update_contact_field tool when it fires.
//
// Overwrite semantics match QualifyingQuestion.overwrite:
//   overwrite=false → only set if the field is currently empty (keep first)
//   overwrite=true  → always apply the latest value
model AgentRule {
  id                    String   @id @default(cuid())
  agentId               String
  agent                 Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  name                  String                 // "Out of town"
  conditionDescription  String   @db.Text      // "contact indicates they are out of town or traveling"
  examples              String[] @default([])  // few-shot phrases

  targetFieldKey        String                 // "custom.out_of_town" | "contact.firstName"
  targetValue           String                 // "true", "Yes", "Away until Monday"
  overwrite             Boolean  @default(false)

  isActive              Boolean  @default(true)
  order                 Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([agentId, isActive, order])
}

model MessageLog {
  id               String    @id @default(cuid())
  locationId       String
  location         Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  agentId          String?
  agent            Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  contactId        String
  conversationId   String
  inboundMessage   String    @db.Text
  outboundReply    String?   @db.Text
  actionsPerformed String[]
  tokensUsed       Int       @default(0)
  toolCallTrace    Json?
  status           LogStatus @default(PENDING)
  errorMessage     String?   @db.Text
  createdAt        DateTime  @default(now())

  // ─── Approval Queue ───
  needsApproval    Boolean   @default(false)
  approvalStatus   String?                    // "pending" | "approved" | "rejected" | "auto_sent"
  approvedBy       String?                    // userId
  approvedAt       DateTime?
  approvalReason   String?                    // why it was flagged (e.g. "low_sentiment", "first_contact")
  // Channel + conversationProviderId captured at agent-run time so the
  // approval release can send on the same channel the inbound arrived on.
  approvalChannel          String?
  approvalConversationProviderId String?

  // ─── Inline Correction ───
  corrections      MessageCorrection[]

  @@index([locationId, createdAt(sort: Desc)])
  @@index([agentId, createdAt(sort: Desc)])
  @@index([needsApproval, approvalStatus])
}

enum LogStatus {
  PENDING
  SUCCESS
  ERROR
  SKIPPED
}

model MessageCorrection {
  id             String     @id @default(cuid())
  messageLogId   String
  messageLog     MessageLog @relation(fields: [messageLogId], references: [id], onDelete: Cascade)
  originalText   String     @db.Text
  correctedText  String     @db.Text
  correctedBy    String                       // userId
  reason         String?    @db.Text          // optional note for training
  savedAsKnowledge Boolean  @default(false)
  createdAt      DateTime   @default(now())
  @@index([messageLogId])
  @@index([correctedBy, createdAt(sort: Desc)])
}

// ─── Agent Prompt Versioning ───────────────────────────────────────────────
model AgentPromptVersion {
  id             String   @id @default(cuid())
  agentId        String
  systemPrompt   String   @db.Text
  instructions   String?  @db.Text
  changeNote     String?  @db.Text
  editedBy       String                       // userId
  isRollback     Boolean  @default(false)
  createdAt      DateTime @default(now())
  @@index([agentId, createdAt(sort: Desc)])
}

// ─── Agent Evaluation (Test Suite) ─────────────────────────────────────────
model AgentEvaluation {
  id                 String   @id @default(cuid())
  agentId            String
  name               String
  scenario           String   @db.Text          // inbound message to test
  expectedContains   String[] @default([])      // substrings that SHOULD be in reply
  expectedNotContains String[] @default([])     // substrings that SHOULD NOT
  expectedTool       String?                    // specific tool that should be called
  createdAt          DateTime @default(now())
  runs               AgentEvaluationRun[]
  @@index([agentId])
}

model AgentEvaluationRun {
  id             String          @id @default(cuid())
  evaluationId   String
  evaluation     AgentEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  actualResponse String?         @db.Text
  passed         Boolean
  failureReasons String[]        @default([])
  toolsCalled    String[]        @default([])
  runBy          String                          // userId
  runAt          DateTime        @default(now())
  @@index([evaluationId, runAt(sort: Desc)])
}

// ─── Agent Goals + Win/Loss ────────────────────────────────────────────────
model AgentGoal {
  id          String   @id @default(cuid())
  agentId     String
  name        String
  goalType    String                              // "appointment_booked" | "tag_added" | "opportunity_moved" | "custom"
  value       String?                             // e.g. the tag name or stage name for matching
  isActive    Boolean  @default(true)
  maxTurns    Int?                                // optional: win only counts if hit within N turns
  // ─── Behavioural (how the agent should pursue the goal) ───
  isPrimary      Boolean  @default(false)         // primary objective — pinned to top of system prompt
  priority       Int      @default(10)            // lower = more important (secondary objectives)
  aggressiveness String   @default("moderate")    // "soft" | "moderate" | "aggressive"
  triggerPhrases String[] @default([])            // phrases that should immediately pursue this goal
  preferredTool  String?                          // tool to use when pursuing (e.g. "book_appointment")
  instruction    String?  @db.Text                // custom instruction appended to the prompt
  createdAt      DateTime @default(now())
  events         AgentGoalEvent[]
  @@index([agentId])
  @@index([agentId, isPrimary, priority])
}

model AgentGoalEvent {
  id             String   @id @default(cuid())
  goalId         String
  goal           AgentGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  contactId      String
  conversationId String?
  achievedAt     DateTime @default(now())
  turnsToAchieve Int?
  @@index([goalId, achievedAt(sort: Desc)])
  @@index([contactId])
}

// ─── Audit Log ─────────────────────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  actorId     String                              // userId who performed the action
  action      String                              // "agent.paused" | "message.approved" | ...
  targetType  String?                             // "agent" | "message" | "workspace" | ...
  targetId    String?
  metadata    Json?                               // free-form context
  createdAt   DateTime @default(now())
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
}

// ─── Consent Tracking (TCPA / GDPR) ────────────────────────────────────────
model ContactConsent {
  id          String   @id @default(cuid())
  workspaceId String
  locationId  String
  contactId   String
  channel     String                              // "SMS" | "Email" | "WhatsApp" | ...
  status      String                              // "opted_in" | "opted_out" | "unknown"
  source      String?                             // "manual" | "keyword" | "webform" | ...
  detail      String?  @db.Text                   // e.g. the keyword that triggered opt-out
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([contactId, channel, workspaceId])
  @@index([workspaceId, status])
}

// ─── Live Takeover ─────────────────────────────────────────────────────────
model LiveTakeover {
  id             String   @id @default(cuid())
  agentId        String
  contactId      String
  conversationId String?
  locationId     String
  takenOverBy    String                           // userId
  reason         String?  @db.Text
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  @@index([agentId, endedAt])
  @@index([contactId, endedAt])
}

// ─── Webhook Subscriptions ─────────────────────────────────────────────────
model WebhookSubscription {
  id          String   @id @default(cuid())
  workspaceId String
  url         String
  events      String[] @default([])              // ["message.sent","appointment.booked",...]
  secret      String                              // for HMAC signing
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveries  WebhookDelivery[]
  @@index([workspaceId])
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  statusCode     Int?
  responseBody   String?  @db.Text
  attempts       Int      @default(1)
  succeeded      Boolean  @default(false)
  deliveredAt    DateTime @default(now())
  @@index([subscriptionId, deliveredAt(sort: Desc)])
}

// ─── Agent Templates Marketplace ───────────────────────────────────────────
model AgentTemplate {
  id                 String   @id @default(cuid())
  slug               String   @unique
  name               String
  description        String   @db.Text
  category           String                       // "sales" | "support" | "real_estate" | ...
  icon               String   @default("🤖")
  systemPrompt       String   @db.Text
  suggestedTools     String[] @default([])
  suggestedChannels  String[] @default([])
  sampleQualifyingQuestions Json?
  isOfficial         Boolean  @default(false)
  installCount       Int      @default(0)
  createdAt          DateTime @default(now())
  @@index([category])
}

// ─── Notification Channels (Slack + Email) ─────────────────────────────────
model NotificationChannel {
  id          String   @id @default(cuid())
  workspaceId String
  type        String                              // "slack" | "email"
  config      Json                                // { webhookUrl?: string, email?: string }
  events      String[] @default([])              // ["needs_attention","approval_pending",...]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@index([workspaceId, type])
}

model StopCondition {
  id            String            @id @default(cuid())
  agentId       String
  agent         Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conditionType StopConditionType
  value         String?
  pauseAgent    Boolean           @default(true)
  createdAt     DateTime          @default(now())
  @@index([agentId])
}

model FollowUpSequence {
  id            String         @id @default(cuid())
  agentId       String
  agent         Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name          String
  isActive      Boolean        @default(true)
  triggerType   String         @default("always")   // "always" | "no_reply" | "keyword" | "agent"
  triggerValue  String?                               // hours for no_reply, comma-sep keywords for keyword, null for agent/always
  steps         FollowUpStep[]
  jobs          FollowUpJob[]
  createdAt     DateTime       @default(now())
  @@index([agentId])
}

model FollowUpStep {
  id         String           @id @default(cuid())
  sequenceId String
  sequence   FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber Int
  delayHours Int
  message    String           @db.Text
  @@index([sequenceId, stepNumber])
}

model FollowUpJob {
  id             String           @id @default(cuid())
  sequenceId     String
  sequence       FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  locationId     String
  contactId      String
  conversationId String?
  channel        String           @default("SMS")
  currentStep    Int              @default(1)
  status         FollowUpStatus   @default(SCHEDULED)
  scheduledAt    DateTime
  lastSentAt     DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime         @default(now())
  @@index([status, scheduledAt])
  @@index([locationId, contactId])
}

model QualifyingQuestion {
  id           String   @id @default(cuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  question     String   @db.Text
  fieldKey     String
  required     Boolean  @default(true)
  order        Int      @default(0)
  answerType   String   @default("text")
  choices      String[] @default([])
  conditionOp  String?
  conditionVal String?
  actionType   String?
  actionValue  String?
  crmFieldKey  String?
  overwrite    Boolean  @default(false)
  createdAt    DateTime @default(now())
  @@index([agentId, order])
}

model ConversationStateRecord {
  id                String            @id @default(cuid())
  agentId           String
  agent             Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  locationId        String
  contactId         String
  conversationId    String?
  state             ConversationState @default(ACTIVE)
  messageCount      Int               @default(0)
  pauseReason       String?
  pausedAt          DateTime?
  resumedAt         DateTime?
  qualifyingAnswers Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  @@unique([agentId, contactId])
  @@index([locationId, state])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  locationId     String
  contactId      String
  conversationId String
  role           String
  content        String   @db.Text
  createdAt      DateTime @default(now())
  @@index([agentId, contactId, createdAt(sort: Asc)])
  @@index([conversationId, createdAt(sort: Asc)])
}

// ─── Listening Rules ──────────────────────────────────────────────────────
// "IF the contact mentions something in category X, THEN capture it in the
// agent's memory of this contact." Unlike detection rules (AgentRule) which
// write a known value to a known field, listening rules capture free-text
// context the user couldn't have anticipated — family news, health issues,
// personal preferences. The agent writes the content; the user only
// declares what categories are worth listening for.
model AgentListeningRule {
  id                    String   @id @default(cuid())
  agentId               String
  agent                 Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  name                  String                 // "Family context", "Pain points"
  description           String   @db.Text      // "family members, health issues, life events"
  examples              String[] @default([])  // illustrative phrases

  isActive              Boolean  @default(true)
  order                 Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([agentId, isActive, order])
}

model ContactMemory {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  locationId String
  contactId  String
  summary    String?  @db.Text                 // auto-generated conversation summary
  categories Json?                              // { "Family context": "mum is sick", ... } — keyed by listening rule name
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  @@unique([agentId, contactId])
}

model AgentTrigger {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  eventType       String                         // "ContactCreate" | "ContactTagUpdate"
  tagFilter       String?                        // only fire when this specific tag is present/added
  channel         String   @default("SMS")       // which channel to send on: "SMS" | "WhatsApp" | "Email" etc.
  messageMode     String   @default("AI_GENERATE") // "FIXED" | "AI_GENERATE"
  fixedMessage    String?  @db.Text              // static first message (when mode=FIXED)
  aiInstructions  String?  @db.Text              // extra context for the AI (when mode=AI_GENERATE)
  delaySeconds    Int      @default(0)           // optional delay before sending (0 = immediate)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agentId])
  @@index([eventType, isActive])
}

model ChannelDeployment {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  channel    String                         // "SMS" | "WhatsApp" | "GMB" | "FB" | "IG" | "Live_Chat" | "Email"
  isActive   Boolean  @default(true)
  config     Json?                          // channel-specific settings (e.g. WhatsApp template, FB page ID)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@unique([agentId, channel])
  @@index([channel, isActive])
}

model VapiConfig {
  id              String   @id @default(cuid())
  agentId         String   @unique
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  phoneNumberId   String?
  phoneNumber     String?
  voiceProvider   String   @default("elevenlabs")
  voiceId         String   @default("EXAVITQu4vr4xnSDxMaL")
  voiceName       String?
  stability       Float    @default(0.5)
  similarityBoost Float    @default(0.75)
  speed           Float    @default(1.0)
  style           Float    @default(0.0)
  firstMessage    String?  @db.Text
  endCallMessage  String?  @db.Text
  maxDurationSecs Int      @default(600)
  recordCalls     Boolean  @default(true)
  backgroundSound String?
  endCallPhrases  String[] @default([])
  language        String?
  voiceTools      Json?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CallLog {
  id           String   @id @default(cuid())
  locationId   String
  agentId      String?
  contactId    String?
  contactPhone String?
  vapiCallId   String?  @unique
  direction    String   @default("inbound")
  status       String   @default("completed")
  durationSecs Int?
  transcript   String?  @db.Text
  summary      String?  @db.Text
  recordingUrl String?
  tokensUsed    Int      @default(0)
  endedReason   String?
  triggerSource String?
  createdAt     DateTime @default(now())
  @@index([locationId, createdAt(sort: Desc)])
  @@index([agentId, createdAt(sort: Desc)])
}

model ScheduledMessage {
  id           String   @id @default(cuid())
  locationId   String
  agentId      String?
  contactId    String
  channel      String   @default("SMS")
  message      String   @db.Text
  scheduledAt  DateTime
  sentAt       DateTime?
  status       String   @default("pending")  // pending, sent, cancelled, failed
  createdAt    DateTime @default(now())
  @@index([status, scheduledAt])
  @@index([locationId, contactId])
}

model LeadScore {
  id         String   @id @default(cuid())
  locationId String
  agentId    String
  contactId  String
  score      Int
  reason     String
  createdAt  DateTime @default(now())
  @@unique([agentId, contactId])
  @@index([locationId, score(sort: Desc)])
}

model MessageBuffer {
  id             String   @id @default(cuid())
  locationId     String
  contactId      String
  conversationId String
  body           String   @db.Text
  processed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  @@index([locationId, contactId, processed, createdAt(sort: Asc)])
}

model Integration {
  id          String   @id @default(cuid())
  locationId  String
  type        String
  name        String
  credentials Json
  config      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([locationId, type])
}

// ─── Chat Widgets (Intercom-clone) ──────────────────────────────────────────

model ChatWidget {
  id                String   @id @default(cuid())
  workspaceId       String
  name              String
  publicKey         String   @unique
  // Appearance
  primaryColor      String   @default("#fa4d2e")
  logoUrl           String?
  title             String   @default("Chat with us")
  subtitle          String   @default("We typically reply within a minute")
  welcomeMessage    String   @db.Text @default("Hi! How can we help?")
  position          String   @default("bottom-right")
  // Identity
  requireEmail      Boolean  @default(false)
  askForNameEmail   Boolean  @default(true)
  // Voice
  voiceEnabled      Boolean  @default(false)
  voiceAgentId      String?
  // Routing
  defaultAgentId    String?
  allowedDomains    String[] @default([])
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  visitors          WidgetVisitor[]
  conversations     WidgetConversation[]
  @@index([workspaceId])
}

model WidgetVisitor {
  id            String   @id @default(cuid())
  widgetId      String
  widget        ChatWidget @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  cookieId      String
  email         String?
  name          String?
  phone         String?
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  crmContactId  String?
  userAgent     String?
  ipAddress     String?
  conversations WidgetConversation[]
  @@unique([widgetId, cookieId])
  @@index([widgetId, lastSeenAt])
}

model WidgetConversation {
  id            String   @id @default(cuid())
  widgetId      String
  widget        ChatWidget @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  visitorId     String
  visitor       WidgetVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  agentId       String?
  status        String   @default("active")
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  messages      WidgetMessage[]
  voiceCalls    WidgetVoiceCall[]
  @@index([widgetId, lastMessageAt(sort: Desc)])
  @@index([visitorId])
  @@index([agentId, status])
}

model WidgetMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   WidgetConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String   @db.Text
  kind           String   @default("text")
  createdAt      DateTime @default(now())
  @@index([conversationId, createdAt(sort: Asc)])
}

model WidgetVoiceCall {
  id             String   @id @default(cuid())
  conversationId String
  conversation   WidgetConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  vapiCallId     String?
  status         String   @default("requested")
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  durationSecs   Int?
  transcript     String?  @db.Text
  @@index([conversationId])
}
